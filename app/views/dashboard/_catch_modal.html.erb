<%# Quick-Catch Modal — restyled in Game Boy theme %>
<div data-dashboard-target="catchModal"
     class="hidden"
     style="position: fixed; inset: 0; z-index: 50;">
  <div data-action="click->dashboard#closeCatchModal"
       style="position: absolute; inset: 0; background: rgba(15, 56, 15, 0.75);"></div>

  <div style="position: relative; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 16px;">
    <div class="gb-modal">
      <div class="gb-modal-title">
        NEW CATCH
        <button data-action="click->dashboard#closeCatchModal"
                class="gb-modal-close">&times;</button>
      </div>

      <form data-action="submit->dashboard#submitCatch">
        <%# Nickname %>
        <div style="margin-bottom: 12px;">
          <label class="gb-label">NICKNAME</label>
          <input type="text" required autocomplete="off"
                 data-dashboard-target="catchNickname"
                 class="gb-input"
                 placeholder="e.g. Tommy, RACHEL...">
        </div>

        <%# Location %>
        <div style="margin-bottom: 12px;">
          <label class="gb-label">LOCATION</label>
          <select data-dashboard-target="catchLocation"
                  required
                  class="gb-select">
            <option value="">Select location...</option>
            <% @locations.each do |key, data| %>
              <option value="<%= key %>"><%= data['name'] %></option>
            <% end %>
          </select>
        </div>

        <%# Species %>
        <div style="margin-bottom: 12px;">
          <label class="gb-label">YOUR SPECIES</label>
          <input type="text" required autocomplete="off" list="pokedex-species"
                 data-dashboard-target="catchSpecies"
                 class="gb-input"
                 placeholder="Search species...">
          <datalist id="pokedex-species">
            <% @pokedex_species.each do |species| %>
              <option value="<%= species %>">
            <% end %>
          </datalist>
        </div>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 16px;">
          <span data-dashboard-target="catchStatus" style="font-size: 10px; color: var(--d2);"></span>
          <div style="display: flex; gap: 8px;">
            <button type="button"
                    data-action="click->dashboard#closeCatchModal"
                    class="gb-btn gb-btn-sm">
              Cancel
            </button>
            <button type="submit" class="gb-btn-primary gb-btn-sm">
              Catch!
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>
