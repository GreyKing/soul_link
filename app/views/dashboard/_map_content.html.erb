<div class="panel-header">
  <span>MAP</span>
  <span class="panel-header-sub">SINNOH REGION</span>
</div>
<div class="panel-body">
  <%# ASCII Map — large version for center panel %>
  <% current_loc = @next_gym ? @locations[@next_gym["location"]]&.[]("name") : "Sunyshore City" %>
  <div class="map-area" style="font-size: 11px; line-height: 1.6;"><%= pixeldex_ascii_map(current_loc.to_s) %></div>

  <%# Current Location %>
  <div class="route-card">
    <div class="route-label">CURRENT LOCATION</div>
    <% if @next_gym %>
      <% loc_data = @locations[@next_gym["location"]] %>
      <div class="route-name"><%= loc_data&.[]("name")&.upcase || @next_gym["location"].upcase %></div>
      <div class="route-detail">Preparing for Gym <%= @gyms_defeated + 1 %></div>
      <div class="route-detail">Next objective: <%= @next_gym["leader"]&.upcase %></div>
    <% else %>
      <div class="route-name">POKEMON LEAGUE</div>
      <div class="route-detail">All gyms defeated!</div>
      <div class="route-detail">Prepare for the Elite Four</div>
    <% end %>
  </div>

  <%# Recent Routes — expanded for center panel %>
  <% if @current_segment %>
    <div class="route-card">
      <div class="route-label">ROUTES IN CURRENT SEGMENT</div>
      <div style="font-size: 10px; line-height: 2;">
        <% (@current_segment["locations"] || []).each do |loc_key| %>
          <% loc_data = @locations[loc_key] %>
          <% has_catch = @groups_by_location[loc_key]&.any? %>
          <div>
            <%= has_catch ? "&#9733;".html_safe : "." %>
            <%= loc_data&.[]("name") || loc_key %> -
            <% if has_catch %>
              <% group = @groups_by_location[loc_key].first %>
              <span style="<%= group.dead? ? 'color: #e8a0a0;' : '' %>"><%= group.dead? ? "\u{1F480} " : '' %><%= group.nickname %></span>
            <% else %>
              <span style="color: var(--d2);">uncaught</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="dialog" style="font-size: 11px;">
    <%= pixeldex_gym_strategy(@next_gym, @type_analysis) %>
  </div>
</div>
