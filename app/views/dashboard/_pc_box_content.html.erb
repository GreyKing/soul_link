<%#
  Step 22 R2 — PC Box redesign per handoff/2026-05-04-ui-audit-mockup-pc-box.html.

  Surfaces:
    1. REVIEW PARSED CATCHES tray (auto-detected catches with badge legend
       + per-row LOG / EDIT / SKIP actions).
    2. Filter chip bar (ALL · ON TEAM · STORAGE · FALLEN) + free-text search.
    3. Unified box grid (merged on-team + storage + fallen with corner glyphs).
    4. Type-coverage rail (right side; stacks below at <900px).

  Implementation notes:
    - Wrapping `.pc-box-r2` namespaces every new CSS rule so we don't
      regress the sidebar (`_pc_box_panel.html.erb`) which still uses
      `.box-grid` / `.box-cell` from the legacy rules.
    - LOG/EDIT chain: `dashboard#openCatchModal` first (clears + focuses),
      then `review-tray#prefillCatch` (populates targets). Reversing this
      order would have the pre-fill wiped. The catch modal is keyed by
      Stimulus targets (`data-dashboard-target=*`), not `name=`.
    - SKIP is client-side only: toggles `.dismissed` + decrements the
      tray count. Does not persist (KG-35).
%>
<%
  total = @on_team_groups.size + @storage_groups.size + @fallen_groups.size
  auto_catches = (@auto_detected_catches || []).reject { |p| p.id.nil? }
  first_ids_by_location = auto_catches
    .group_by { |p| p.location.to_s }
    .each_with_object({}) { |(loc, list), out| out[loc] = list.min_by { |p| p.caught_at || Time.at(0) }.id }
  read_only = dashboard_read_only?(@run)

  status_groups = []
  @on_team_groups.each  { |g| status_groups << [ g, "team" ] }
  @storage_groups.each  { |g| status_groups << [ g, "storage" ] }
  @fallen_groups.each   { |g| status_groups << [ g, "fallen" ] }
%>

<div class="pc-box-r2"
     data-controller="pc-box-filter review-tray"
     data-pc-box-filter-total-value="<%= total %>">

  <div class="panel-header">
    <span>PC BOX</span>
    <span style="display: flex; align-items: center; gap: 8px;">
      <span class="panel-header-sub" data-pc-box-filter-target="count">
        <%= total %> TOTAL ·
        <% if auto_catches.any? %>
          <%= auto_catches.size %> NEW PARSED
        <% else %>
          ALL CAUGHT-UP
        <% end %>
      </span>
      <% unless read_only %>
        <button type="button"
                data-action="click->dashboard#openCatchModal"
                class="gb-btn-primary gb-btn-sm" style="font-size: 9px; padding: 3px 8px;">
          + NEW CATCH
        </button>
      <% end %>
    </span>
  </div>

  <div class="panel-body">

    <% if auto_catches.any? %>
      <%# Step 27: collapsed multi-row badge-legend into a single inline
          strip. Count is now plain text (no chip background) — the
          span itself is the review-tray#count target so the dismiss
          rewrite (`${remaining} NEW`) keeps working. %>
      <div class="review-tray">
        <div class="review-tray-head">
          <h3>REVIEW PARSED CATCHES</h3>
          <span class="count" data-review-tray-target="count"><%= auto_catches.size %> NEW</span>
        </div>

        <div class="badge-legend" aria-label="Badge legend">
          LEGEND:
          <span class="row"><span class="badge">1ST</span> first encounter</span>
          <span class="row"><span class="badge">TRADE-IN</span> traded</span>
          <span class="row"><span class="badge">EVENT</span> mystery gift</span>
          <span class="row"><span class="badge">OFF-FEED</span> from PC box</span>
        </div>

        <% auto_catches.each do |p| %>
          <%
            is_first = first_ids_by_location[p.location.to_s] == p.id
            is_event = p.acquired_via == "event_gift"
            recommended = recommended_review_action(p)
            highlight = is_first && recommended == :log
            log_label = is_event ? "LOG AGAIN" : "LOG CATCH"
            stats_bits = []
            stats_bits << p.nature.to_s.upcase if p.nature.present?
            if p.ivs.is_a?(Hash)
              ivs = [ p.ivs["hp"], p.ivs["atk"], p.ivs["def"], p.ivs["spe"], p.ivs["spa"], p.ivs["spd"] ].compact
              stats_bits << "IVS #{ivs.join('/')}" if ivs.any?
            end
            if p.moves.is_a?(Array)
              move_names = p.moves.first(4).filter_map { |m| format_move_name(m["id"]) if m.is_a?(Hash) && m["id"].to_i.positive? }
              stats_bits << move_names.join(" · ") if move_names.any?
            end
          %>
          <div class="review-row<%= ' first' if highlight %>"
               data-review-tray-target="row"
               data-pid="<%= p.pid %>">
            <div class="sprite">
              <% if p.species.present? %>
                <%= pokemon_sprite_tag(p.species, size: 56) %>
              <% else %>
                SPR
              <% end %>
            </div>
            <div class="meta">
              <div class="name">
                <%= p.species.to_s.upcase.presence || "???" %>
                <% if is_first %>
                  <span class="badge first">1ST</span>
                <% end %>
                <% if p.trade_in %>
                  <span class="badge trade">TRADE-IN</span>
                <% end %>
                <% if is_event %>
                  <span class="badge event">EVENT</span>
                <% end %>
                <% if p.caught_off_feed %>
                  <span class="badge offfeed">OFF-FEED</span>
                <% end %>
              </div>
              <div class="loc">
                <%= p.location %><% if p.level %> · Lv <%= p.level %><% end %>
              </div>
              <% if stats_bits.any? %>
                <div class="stats"><%= stats_bits.join(" · ") %></div>
              <% end %>
            </div>
            <div class="actions">
              <% unless read_only %>
                <button type="button"
                        class="<%= 'primary' if recommended == :log %>"
                        data-action="click->dashboard#openCatchModal click->review-tray#prefillCatch"
                        data-review-tray-prefill-species-param="<%= p.species %>"
                        data-review-tray-prefill-location-param="<%= p.location %>">
                  <%= log_label %>
                </button>
                <button type="button"
                        data-action="click->dashboard#openCatchModal click->review-tray#prefillCatch"
                        data-review-tray-prefill-species-param="<%= p.species %>"
                        data-review-tray-prefill-location-param="<%= p.location %>">
                  EDIT
                </button>
              <% end %>
              <button type="button"
                      class="<%= 'primary' if recommended == :skip %>"
                      data-action="click->review-tray#dismiss">
                SKIP
              </button>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <%# Step 27: standalone .check glyph dropped in favour of an
          inline (✓) text prefix. Container restyled to gb-flash-notice. %>
      <div class="empty-tray-bar" role="status">
        (✓) No new parsed catches to review. New saves will land here for confirmation.
      </div>
    <% end %>

    <div class="filter-bar">
      <button type="button"
              class="filter-chip active"
              data-action="click->pc-box-filter#applyFilter"
              data-pc-box-filter-target="chip"
              data-pc-box-filter-status-param="all"
              data-status="all">
        ALL · <%= total %>
      </button>
      <button type="button"
              class="filter-chip"
              data-action="click->pc-box-filter#applyFilter"
              data-pc-box-filter-target="chip"
              data-pc-box-filter-status-param="team"
              data-status="team">
        ON TEAM · <%= @on_team_groups.size %>
      </button>
      <button type="button"
              class="filter-chip"
              data-action="click->pc-box-filter#applyFilter"
              data-pc-box-filter-target="chip"
              data-pc-box-filter-status-param="storage"
              data-status="storage">
        STORAGE · <%= @storage_groups.size %>
      </button>
      <button type="button"
              class="filter-chip"
              data-action="click->pc-box-filter#applyFilter"
              data-pc-box-filter-target="chip"
              data-pc-box-filter-status-param="fallen"
              data-status="fallen">
        FALLEN · <%= @fallen_groups.size %>
      </button>
      <div class="filter-search">
        <input type="search"
               class="filter-search-input"
               aria-label="Search nicknames or species"
               placeholder="Search nickname or species…"
               data-action="input->pc-box-filter#applySearch"
               data-pc-box-filter-target="searchInput">
      </div>
    </div>

    <div class="box-layout">
      <div class="box-grid">
        <% status_groups.each do |group, status| %>
          <%
            my_pokemon = group.soul_link_pokemon.find { |g| g.discord_user_id == current_user_id }
            cell_class = if status == "team" then "team"
            elsif status == "fallen" then "dead"
            end
            marker = case status
                     when "team"    then "★"
                     when "storage" then "▣"
                     when "fallen"  then "☠"
            end
            search_haystack = [ group.nickname, my_pokemon&.species ].compact.join(" ").downcase
          %>
          <div class="box-cell <%= cell_class %>"
               data-pc-box-filter-target="cell"
               data-status="<%= status %>"
               data-search-haystack="<%= search_haystack %>"
               data-action="click->pixeldex#selectPokemon"
               data-group-id="<%= group.id %>"
               data-group-nickname="<%= group.nickname %>"
               data-group-species="<%= my_pokemon&.species || '' %>"
               data-group-location="<%= group.location %>"
               data-group-status="<%= group.dead? ? 'dead' : 'caught' %>"
               data-group-types="<%= my_pokemon&.species.present? ? SoulLink::GameState.types_for(my_pokemon.species).join(',') : '' %>"
               data-group-pokemon="<%= pixeldex_group_pokemon_json(group, current_user_id) %>"
               aria-label="<%= group.nickname %>, <%= status %>, <%= group.location %>">
            <span class="group-marker" aria-hidden="true"><%= marker %></span>
            <div class="nick"><%= group.nickname.upcase %></div>
            <div class="sprite">
              <% if my_pokemon&.species.present? %>
                <%= pokemon_sprite_tag(my_pokemon.species, size: 40) %>
              <% end %>
            </div>
            <div class="loc"><%= group.location %></div>
          </div>
        <% end %>
      </div>

      <%
        coverage = pixeldex_type_coverage(@type_analysis)
        weaknesses = (@type_analysis[:shared_weaknesses] || []).first(3)
      %>
      <aside class="type-coverage" data-pc-box-filter-target="rail">
        <h3>TYPE COVERAGE</h3>
        <div class="dimmed-explainer">computed against your 6-slot team — switch to ON TEAM to focus</div>

        <div class="sub">COVERED · <%= coverage[:covered].size %></div>
        <div>
          <% if coverage[:covered].any? %>
            <% coverage[:covered].each do |abbr| %>
              <span class="type-pill covered"><%= abbr %></span>
            <% end %>
          <% else %>
            <span style="color: var(--d2); font-size: 11px;">No coverage yet</span>
          <% end %>
        </div>

        <% if coverage[:gaps].any? %>
          <div class="sub">GAPS · <%= coverage[:gaps].size %></div>
          <div>
            <% coverage[:gaps].each do |abbr| %>
              <span class="type-pill gap"><%= abbr %></span>
            <% end %>
          </div>
        <% end %>

        <% if weaknesses.any? %>
          <div class="sub">SHARED WEAKNESSES</div>
          <div>
            <% weaknesses.each do |w| %>
              <span class="type-pill weak"><%= (PixeldexHelper::TYPE_ABBREVIATIONS[w[:type]] || w[:type].to_s[0..2].upcase) %> ×<%= w[:count] %></span>
            <% end %>
          </div>
        <% end %>
      </aside>
    </div>

  </div>
</div>
