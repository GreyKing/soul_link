<%
  total_count = @on_team_groups.size + @storage_groups.size + @fallen_groups.size
%>
<div class="panel-header">
  <span>PC BOX - ALL POKEMON</span>
  <span style="display: flex; align-items: center; gap: 8px;">
    <span class="panel-header-sub"><%= total_count %> TOTAL</span>
    <%# Step 19 — hide the catch modal trigger in read-only mode. %>
    <% unless dashboard_read_only?(@run) %>
      <button type="button"
              data-action="click->dashboard#openCatchModal"
              class="gb-btn-primary gb-btn-sm" style="font-size: 9px; padding: 3px 8px;">
        + NEW CATCH
      </button>
    <% end %>
  </span>
</div>
<div class="panel-body">

  <%# Step 17 — AUTO-DETECTED CATCHES (per-player) %>
  <%
    auto_catches = @auto_detected_catches || []
    # First-encounter computation: per (location), pick the earliest by caught_at.
    # Done here so the view stays a pure render — controller doesn't need to
    # ship a precomputed set just for this badge.
    first_ids_by_location = auto_catches
      .group_by { |p| p.location.to_s }
      .each_with_object({}) { |(loc, list), out| out[loc] = list.min_by { |p| p.caught_at || Time.at(0) }.id }
  %>
  <% if auto_catches.any? %>
    <div class="box-section-label" title="Auto-detected from your save file (PartyParser)">
      AUTO-DETECTED CATCHES (<%= auto_catches.size %>)
    </div>
    <div class="box-grid box-grid-wide" data-pixeldex-target="autoCatchesGrid">
      <% auto_catches.each do |p| %>
        <% first = first_ids_by_location[p.location.to_s] == p.id %>
        <div class="box-cell <%= 'on-team' if first %>"
             data-group-pid="<%= p.pid %>"
             data-group-species="<%= p.species %>"
             data-group-location="<%= p.location %>"
             data-group-status="auto">
          <div class="box-cell-name" style="margin-bottom: 4px;">
            <%= p.species.to_s.upcase %>
            <% if first %>
              <span class="type-text" style="margin-left:4px; border-color: var(--amber); color: var(--amber);" title="First encounter on this route">1ST</span>
            <% end %>
            <% if p.trade_in %>
              <span class="type-text" style="margin-left:4px; border-color: var(--amber); color: var(--amber);" title="Acquired via trade">TRADE-IN</span>
            <% end %>
            <% if p.acquired_via == "event_gift" %>
              <span class="type-text" style="margin-left:4px; border-color: var(--d2); color: var(--d2);" title="Event / mystery-gift Pokemon — not a Soul Link encounter">EVENT</span>
            <% end %>
            <% if p.caught_off_feed %>
              <span class="type-text" style="margin-left:4px; border-color: var(--d2); color: var(--d2);" title="Detected from PC box rather than the active party">OFF-FEED</span>
            <% end %>
          </div>
          <div class="box-cell-loc"><%= p.location %><% if p.level %> &middot; Lv <%= p.level %><% end %></div>
          <%# Step 18 — collapsible per-Pokémon stats. <details> keeps the
              UX zero-Stimulus and read-only. Step-17 rows render unchanged
              (every guard collapses to false → no <details> block). %>
          <% if p.nature.present? || p.ivs.present? || p.evs.present? || p.moves.present? %>
            <details class="box-cell-detail" style="margin-top: 4px; font-size: 9px; color: var(--d2);">
              <summary style="cursor: pointer;">STATS</summary>
              <% if p.nature.present? %><div>NATURE: <%= p.nature.to_s.upcase %></div><% end %>
              <% if p.ivs.is_a?(Hash) %>
                <div>IVS: <%= [ p.ivs["hp"], p.ivs["atk"], p.ivs["def"], p.ivs["spe"], p.ivs["spa"], p.ivs["spd"] ].compact.join("/") %></div>
              <% end %>
              <% if p.evs.is_a?(Hash) %>
                <div>EVS: <%= [ p.evs["hp"], p.evs["atk"], p.evs["def"], p.evs["spe"], p.evs["spa"], p.evs["spd"] ].compact.join("/") %></div>
              <% end %>
              <% if p.moves.is_a?(Array) %>
                <% p.moves.each_with_index do |m, i| %>
                  <% next unless m.is_a?(Hash) && m["id"].to_i.positive? %>
                  <div>MOVE <%= i + 1 %>: <%= format_move_name(m["id"]) %> &middot; PP <%= m["pp"] %> &middot; &uarr;<%= m["pp_up"] %></div>
                <% end %>
              <% end %>
            </details>
          <% end %>
        </div>
      <% end %>
      <% ((3 - auto_catches.size % 3) % 3).times do %>
        <div class="box-cell empty"></div>
      <% end %>
    </div>
  <% end %>

  <%# ON TEAM section %>
  <div class="box-section-label">&#9733; ON TEAM (<%= @on_team_groups.size %>)</div>
  <div class="box-grid box-grid-wide" data-pixeldex-target="onTeamGrid">
    <% @on_team_groups.each do |group| %>
      <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
      <div class="box-cell on-team"
           data-action="click->pixeldex#selectPokemon"
           data-group-id="<%= group.id %>"
           data-group-nickname="<%= group.nickname %>"
           data-group-species="<%= my_pokemon&.species || '' %>"
           data-group-location="<%= group.location %>"
           data-group-status="caught"
           data-group-types="<%= my_pokemon&.species.present? ? SoulLink::GameState.types_for(my_pokemon.species).join(',') : '' %>"
           data-group-pokemon="<%= pixeldex_group_pokemon_json(group, current_user_id) %>">
        <div class="box-cell-name" style="margin-bottom: 4px;"><%= group.nickname.upcase %></div>
        <div class="box-cell-players">
          <%= pixeldex_player_sprites(group, current_user_id) %>
        </div>
        <div class="box-cell-loc"><%= group.location %></div>
      </div>
    <% end %>
    <% ((3 - @on_team_groups.size % 3) % 3).times do %>
      <div class="box-cell empty"></div>
    <% end %>
  </div>

  <%# IN STORAGE section %>
  <div class="box-section-label" style="margin-top: 14px;">IN STORAGE (<%= @storage_groups.size %>)</div>
  <div class="box-grid box-grid-wide" data-pixeldex-target="storageGrid">
    <% @storage_groups.each do |group| %>
      <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
      <div class="box-cell"
           data-action="click->pixeldex#selectPokemon"
           data-group-id="<%= group.id %>"
           data-group-nickname="<%= group.nickname %>"
           data-group-species="<%= my_pokemon&.species || '' %>"
           data-group-location="<%= group.location %>"
           data-group-status="caught"
           data-group-types="<%= my_pokemon&.species.present? ? SoulLink::GameState.types_for(my_pokemon.species).join(',') : '' %>"
           data-group-pokemon="<%= pixeldex_group_pokemon_json(group, current_user_id) %>">
        <div class="box-cell-name" style="margin-bottom: 4px;"><%= group.nickname.upcase %></div>
        <div class="box-cell-players">
          <%= pixeldex_player_sprites(group, current_user_id) %>
        </div>
        <div class="box-cell-loc"><%= group.location %></div>
      </div>
    <% end %>
    <% if @storage_groups.empty? %>
      <% 3.times do %><div class="box-cell empty"></div><% end %>
    <% else %>
      <% ((3 - @storage_groups.size % 3) % 3).times do %><div class="box-cell empty"></div><% end %>
    <% end %>
  </div>

  <%# FALLEN section %>
  <div class="box-section-label" style="margin-top: 14px;" title="Pokemon that died this run">FALLEN (<%= @fallen_groups.size %>)</div>
  <div class="box-grid box-grid-wide" data-pixeldex-target="fallenGrid">
    <% @fallen_groups.each do |group| %>
      <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
      <div class="box-cell dead"
           data-action="click->pixeldex#selectPokemon"
           data-group-id="<%= group.id %>"
           data-group-nickname="<%= group.nickname %>"
           data-group-species="<%= my_pokemon&.species || '' %>"
           data-group-location="<%= group.location %>"
           data-group-status="dead"
           data-group-types=""
           data-group-pokemon="<%= pixeldex_group_pokemon_json(group, current_user_id) %>">
        <div class="box-cell-name" style="margin-bottom: 4px;"><%= group.nickname.upcase %></div>
        <div class="box-cell-players">
          <%= pixeldex_player_sprites(group, current_user_id) %>
        </div>
        <div class="box-cell-loc"><%= group.location %></div>
      </div>
    <% end %>
    <% if @fallen_groups.empty? %>
      <% 3.times do %><div class="box-cell empty"></div><% end %>
    <% else %>
      <% ((3 - @fallen_groups.size % 3) % 3).times do %><div class="box-cell empty"></div><% end %>
    <% end %>
  </div>

  <%# Type coverage %>
  <div style="margin-top: 16px; padding-top: 10px; border-top: var(--border-thin);">
    <div class="box-section-label" style="margin-bottom: 6px;">TYPE COVERAGE</div>
    <% coverage = pixeldex_type_coverage(@type_analysis) %>
    <div style="font-size: 10px; line-height: 2.2;">
      <% coverage[:covered].each do |abbr| %>
        <span class="type-text"><%= abbr %></span>
      <% end %>
      <% if coverage[:covered].empty? %>
        <span style="color: var(--d2); font-size: 10px;">No coverage yet</span>
      <% end %>
    </div>
    <% if coverage[:gaps].any? %>
      <div style="margin-top: 6px; font-size: 10px;">
        <span class="type-coverage-gap">
          NO COVERAGE:
          <% coverage[:gaps].each do |abbr| %>
            <span class="type-text" style="border-color: var(--l1);"><%= abbr %></span>
          <% end %>
        </span>
      </div>
    <% end %>
    <% worst = (@type_analysis[:shared_weaknesses] || []).first %>
    <% if worst %>
      <div style="margin-top: 6px; font-size: 10px; color: var(--d2);">
        WEAKNESS: <%= worst[:type].upcase %> x<%= worst[:count] %>
      </div>
    <% end %>
  </div>
</div>
