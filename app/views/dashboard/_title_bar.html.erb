<%# Step 28 — Title bar rebuilt against the PixelDex source spec
    (designs/04-pixeldex.html). Single horizontal `--d2` band:
    `.title-left` (title-block + run-pill) flex-aligned against
    `.title-right` (stat-strip). Stat values render num-on-top
    label-below via column-reverse on each `.item`. The `·`
    separators are kept in DOM but hidden in CSS so the gap does
    the spacing visually.

    The run-picker controller targets + dropdown menu are preserved.
    Each menu option is a real <a href="/?run_id=N"> so switching
    runs works without JS. %>
<%
  player_label = (@player_name.presence || "Trainer").to_s

  current_status_label =
    if @run.completed?
      "HOF"
    elsif @run.read_only?
      "ENDED"
    elsif @run.active?
      "ACTIVE"
    else
      "VIEWING"
    end
%>
<header class="title-bar">
  <div class="title-left">
    <div class="title-block">
      <div class="player"><%= player_label.upcase %>'S PC</div>
      <div class="meta">PLATINUM &middot; SOUL LINK</div>
    </div>

    <div class="run-pill-wrap"
         data-controller="run-picker"
         data-action="keydown->run-picker#navigate">
      <button type="button"
              class="run-pill"
              data-run-picker-target="trigger"
              data-action="click->run-picker#toggle"
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-label="Switch run">
        RUN #<%= @run.run_number %> &mdash; <%= current_status_label %>
        <span class="chev" aria-hidden="true">&#9662;</span>
      </button>

      <div class="run-pill-menu hidden"
           data-run-picker-target="menu"
           role="listbox"
           aria-label="Available runs">
        <% @all_runs.each do |r| %>
          <%
            opt_status_label =
              if r.completed?
                "[🏆 HOF]"
              elsif r.read_only?
                "[ENDED]"
              elsif r.active?
                "[ACTIVE]"
              else
                "[PAST]"
              end
            opt_dates =
              if r.read_only? || r.completed? || !r.active?
                "#{r.created_at.strftime('%b %-d')} &mdash; #{r.updated_at.strftime('%b %-d, %Y')}".html_safe
              else
                "#{r.created_at.strftime('%b %-d')} &mdash; now".html_safe
              end
            is_current = r.id == @run.id
          %>
          <a href="<%= root_path(run_id: r.id) %>"
             class="run-option <%= 'active' if is_current %>"
             role="option"
             aria-selected="<%= is_current ? 'true' : 'false' %>"
             data-run-picker-target="option"
             tabindex="-1">
            <span class="label">RUN #<%= r.run_number %>
              <span class="pill"><%= opt_status_label %></span>
            </span>
            <span class="dates"><%= opt_dates %></span>
          </a>
        <% end %>

        <div class="start-row">
          <%# `+ START NEW RUN` reuses run-management's start_run handler.
              The dashboard `_runs_content.html.erb` partial already
              wraps the dashboard in `data-controller="run-management"`
              so the action resolves up the DOM. %>
          <button type="button"
                  class="start-btn"
                  role="option"
                  aria-selected="false"
                  data-run-picker-target="option"
                  data-action="click->run-management#startRun"
                  tabindex="-1">
            + START NEW RUN
          </button>
        </div>
      </div>
    </div>
  </div>

  <%# Step 28: stat strip wrapped in `.title-right` flex group so it
      docks to the right edge of the `--d2` title band. DOM markup
      preserved (test asserts `<div class="item"><span>LABEL</span>
      <span class="val">N</span>` exact form). Visual num-on-top
      label-below comes from `flex-direction: column-reverse` in
      pixeldex.css. The `·` separators are kept for accessibility
      semantics but hidden via CSS — gap does the visual spacing. %>
  <div class="title-right">
    <div class="stat-strip" aria-label="Run stats">
      <div class="item"><span>CAUGHT</span> <span class="val"><%= @caught_count + @dead_count %></span></div>
      <span class="sep" aria-hidden="true">&middot;</span>
      <div class="item"><span>ALIVE</span> <span class="val"><%= @caught_count %></span></div>
      <span class="sep" aria-hidden="true">&middot;</span>
      <div class="item"><span>DEAD</span> <span class="val"><%= @dead_count %></span></div>
      <span class="sep" aria-hidden="true">&middot;</span>
      <div class="item"><span>BADGES</span> <span class="val"><%= @gyms_defeated %>/8</span></div>
    </div>
  </div>
</header>
