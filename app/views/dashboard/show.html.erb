<%# Real-time refresh: SoulLinkPokemon and SoulLinkPokemonGroup broadcasts
    push a Turbo refresh to this stream on create/update/destroy. With
    morph + scroll preserve, edits in one player's tab show up across all
    open dashboards in the run without a full page reload. %>
<%= turbo_refreshes_with method: :morph, scroll: :preserve %>
<%= turbo_stream_from @run, :dashboard %>

<%# Step 24 R1 — wrap in `.dash-r1` namespace + add `run-management`
    controller at the top so the title-bar `+ START NEW RUN` button
    can reach `run-management#startRun` without wiring two ActionCable
    subscriptions. The window-level numeric jump (1-7) is bound here so
    it works no matter where focus is. %>
<div class="dash-r1"
     data-controller="dashboard pixeldex run-management"
     data-action="keydown@window->pixeldex#numericJump"
     data-dashboard-groups-url-value="<%= pokemon_groups_path %>"
     data-dashboard-csrf-value="<%= form_authenticity_token %>"
     data-dashboard-user-id-value="<%= current_user_id %>"
     data-pixeldex-abilities-data-value="<%= SoulLink::GameState.pokemon_abilities.to_json %>"
     data-pixeldex-evolutions-data-value="<%= SoulLink::GameState.evolutions.to_json %>"
     data-pixeldex-sprite-map-value="<%= pixeldex_sprite_urls.to_json %>"
     data-pixeldex-natures-data-value="<%= PixeldexHelper::NATURES.to_json %>"
     data-pixeldex-pokemon-update-url-value="/pokemon"
     data-pixeldex-group-update-url-value="<%= pokemon_groups_path %>"
     data-pixeldex-update-slots-url-value="<%= update_slots_team_path %>"
     data-pixeldex-csrf-value="<%= form_authenticity_token %>"
     data-run-management-guild-id-value="<%= @guild_id %>"
     data-run-management-user-id-value="<%= current_user_id %>">

  <%= render "title_bar" %>
  <%= render "tab_bar" %>

  <div class="pc-layout">
    <%# Step 28 — left sidebar: always visible compact party. Renders
        `_party_panel` directly; the partial provides its own
        `<div class="panel">` shell so we don't double-wrap. The
        responsive collapse-on-tablet rule targets the first child of
        `.pc-layout` directly. %>
    <%= render "party_panel" %>

    <%# Center: tab-switchable content. Each panel carries the WAI-ARIA
        contract Tab-bar relies on (`role="tabpanel"` + `aria-labelledby`). %>
    <div class="panel">
      <div data-pixeldex-target="tabContent" data-tab="party"
           role="tabpanel" id="panel-party" aria-labelledby="tab-party" tabindex="0"
           class="hidden">
        <%= render "party_detail" %>
      </div>
      <div data-pixeldex-target="tabContent" data-tab="pcbox"
           role="tabpanel" id="panel-pcbox" aria-labelledby="tab-pcbox" tabindex="0">
        <%= render "pc_box_content" %>
      </div>
      <div data-pixeldex-target="tabContent" data-tab="map"
           role="tabpanel" id="panel-map" aria-labelledby="tab-map" tabindex="0"
           class="hidden">
        <%= render "map_content" %>
      </div>
      <div data-pixeldex-target="tabContent" data-tab="gyms"
           role="tabpanel" id="panel-gyms" aria-labelledby="tab-gyms" tabindex="0"
           class="hidden">
        <%= render "gyms_content" %>
      </div>
      <div data-pixeldex-target="tabContent" data-tab="strategy"
           role="tabpanel" id="panel-strategy" aria-labelledby="tab-strategy" tabindex="0"
           class="hidden">
        <%= render "strategy_panel" %>
      </div>
      <div data-pixeldex-target="tabContent" data-tab="runs"
           role="tabpanel" id="panel-runs" aria-labelledby="tab-runs" tabindex="0"
           class="hidden">
        <%= render "runs_content" %>
      </div>
      <div data-pixeldex-target="tabContent" data-tab="calc"
           role="tabpanel" id="panel-calc" aria-labelledby="tab-calc" tabindex="0"
           class="hidden">
        <%= render "calc_content" %>
      </div>
    </div>

    <%# Right rail: consolidated PARTY / GYMS / MAP sub-tabs (Step 24 R1).
        Replaces the old `_map_panel.html.erb` which duplicated MAP + GYMS
        main-tab content. %>
    <%= render "status_rail" %>
  </div>

  <%= render "catch_modal" %>
  <%= render "pokemon_modal" %>
  <%= render "mark_dead_modal" %>
  <%= render "reset_draft_modal" %>
</div>
