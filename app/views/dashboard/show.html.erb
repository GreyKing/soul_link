<%# ── HEADER ── %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-white">Dashboard</h1>
  <p class="text-gray-400 text-sm mt-1"><%= @player_name %>'s play session.</p>
</div>

<div data-controller="dashboard"
     data-dashboard-groups-url-value="<%= pokemon_groups_path %>"
     data-dashboard-csrf-value="<%= form_authenticity_token %>"
     data-dashboard-user-id-value="<%= current_user_id %>">

  <%# ── TOP ROW: Team + Type Analysis ── %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <%# CURRENT TEAM %>
    <div class="bg-gray-800/50 rounded-xl border border-gray-700 p-4">
      <h2 class="text-base font-semibold text-white mb-3">
        Current Team
        <span class="text-sm font-normal text-gray-400">(<%= @team_groups.size %>/<%= SoulLinkTeam::MAX_SLOTS %>)</span>
      </h2>

      <% if @team_groups.any? %>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          <% @team_groups.each_with_index do |group, idx| %>
            <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
            <div class="bg-gray-900/50 rounded-lg border border-gray-700/50 p-3">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xs text-gray-500 font-mono">#<%= idx + 1 %></span>
                <span class="text-xs text-gray-400 truncate"><%= group.nickname %></span>
              </div>
              <% if my_pokemon %>
                <div class="flex items-center gap-2">
                  <%= pokemon_sprite_tag(my_pokemon.species, size: 32) %>
                  <div>
                    <div class="text-sm font-medium text-white"><%= my_pokemon.species %></div>
                    <div class="mt-0.5"><%= pokemon_type_badges(my_pokemon.species, size: :xs) %></div>
                  </div>
                </div>
              <% else %>
                <span class="text-xs text-gray-500 italic">No species assigned</span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm py-4 text-center">
          No team built yet. Visit <%= link_to "My Team", team_path, class: "text-indigo-400 hover:text-indigo-300" %> to build one.
        </p>
      <% end %>
    </div>

    <%# TYPE ANALYSIS %>
    <div class="bg-gray-800/50 rounded-xl border border-gray-700 p-4">
      <h2 class="text-base font-semibold text-white mb-3">Type Analysis</h2>

      <% if @team_pokemon.any? %>
        <%# Offensive coverage %>
        <div class="mb-4">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Offensive Coverage</h3>
          <% if @type_analysis[:offensive_coverage].any? %>
            <div class="flex flex-wrap gap-1 mb-2">
              <% @type_analysis[:offensive_coverage].each do |type_name| %>
                <%= pokemon_type_badge(type_name, size: :xs) %>
              <% end %>
            </div>
          <% end %>
          <% if @type_analysis[:offensive_gaps].any? %>
            <p class="text-xs text-red-400 mb-1">Gaps:</p>
            <div class="flex flex-wrap gap-1">
              <% @type_analysis[:offensive_gaps].each do |type_name| %>
                <span class="inline-block rounded-full text-[10px] px-1.5 py-0.5 font-medium bg-red-900/30 text-red-400 border border-red-800"><%= type_name %></span>
              <% end %>
            </div>
          <% else %>
            <p class="text-xs text-green-400">Full coverage!</p>
          <% end %>
        </div>

        <%# Shared weaknesses %>
        <div class="mb-4">
          <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Shared Weaknesses</h3>
          <% if @type_analysis[:shared_weaknesses].any? %>
            <div class="space-y-1">
              <% @type_analysis[:shared_weaknesses].each do |entry| %>
                <div class="flex items-center gap-1.5">
                  <%= pokemon_type_badge(entry[:type], size: :xs) %>
                  <span class="text-xs text-gray-400"><%= entry[:count] %>/<%= @team_pokemon.size %></span>
                  <% if entry[:count] >= (@team_pokemon.size / 2.0).ceil %>
                    <span class="text-xs text-red-400 font-bold">!</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-xs text-green-400">No shared weaknesses!</p>
          <% end %>
        </div>

        <%# Balance notes %>
        <% if @type_analysis[:balance_notes].any? %>
          <div class="border-t border-gray-700 pt-3 space-y-1">
            <% @type_analysis[:balance_notes].each do |note| %>
              <p class="text-xs <%= note[:level] == :warning ? 'text-yellow-400' : 'text-green-400' %>">
                <%= note[:level] == :warning ? '! ' : '+ ' %><%= note[:message] %>
              </p>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="text-gray-500 text-sm py-4 text-center">Build a team to see type analysis.</p>
      <% end %>
    </div>
  </div>

  <%# ── YOUR POKEMON ── %>
  <div class="bg-gray-800/50 rounded-xl border border-gray-700 p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-base font-semibold text-white">
        Your Pokemon
        <span class="text-sm font-normal text-gray-400">(<%= @all_groups.size %> groups)</span>
      </h2>
      <button type="button"
              data-action="click->dashboard#openCatchModal"
              class="px-3 py-1.5 text-sm bg-indigo-600 text-white rounded-lg hover:bg-indigo-500 transition font-medium">
        + New Catch
      </button>
    </div>

    <% if @all_groups.any? %>
      <div class="space-y-1.5">
        <% @all_groups.each do |group| %>
          <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
          <div class="flex items-center justify-between px-3 py-2 rounded-lg
                      <%= group.dead? ? 'bg-red-950/20 border border-red-900/30' : 'bg-gray-900/50 border border-gray-700/50' %>">
            <div class="flex items-center gap-3 min-w-0">
              <span class="font-medium text-sm truncate w-24 <%= group.dead? ? 'text-red-300' : 'text-white' %>">
                <%= group.dead? ? "\u{1F480} " : '' %><%= group.nickname %>
              </span>
              <span class="text-xs text-gray-500 truncate w-20"><%= group.location %></span>
              <% if my_pokemon %>
                <div class="flex items-center gap-1.5">
                  <%= pokemon_sprite_tag(my_pokemon.species, size: 20) %>
                  <span class="text-xs text-gray-300"><%= my_pokemon.species %></span>
                  <%= pokemon_type_badges(my_pokemon.species, size: :xs) %>
                </div>
              <% else %>
                <span class="text-xs text-gray-600 italic">No species assigned</span>
              <% end %>
            </div>

            <% if group.caught? %>
              <button type="button"
                      data-action="click->dashboard#markDead"
                      data-group-id="<%= group.id %>"
                      data-group-nickname="<%= group.nickname %>"
                      class="text-xs text-gray-500 hover:text-red-400 transition px-2 py-1 rounded hover:bg-red-950/30">
                Mark Dead
              </button>
            <% elsif group.dead? %>
              <span class="text-xs text-red-400/60">Dead</span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm text-center py-6">No pokemon groups yet. Click "+ New Catch" to add one.</p>
    <% end %>
  </div>

  <%# ── QUICK-CATCH MODAL ── %>
  <div data-dashboard-target="catchModal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center">
    <div data-action="click->dashboard#closeCatchModal"
         class="absolute inset-0 bg-black/60"></div>

    <div class="relative bg-gray-800 border border-gray-700 rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold text-white">New Catch</h3>
        <button data-action="click->dashboard#closeCatchModal"
                class="text-gray-400 hover:text-white transition text-2xl leading-none">&times;</button>
      </div>

      <form data-action="submit->dashboard#submitCatch">
        <div class="space-y-4">
          <%# Nickname %>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Nickname</label>
            <input type="text" required autocomplete="off"
                   data-dashboard-target="catchNickname"
                   class="w-full bg-gray-900 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm
                          focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
                   placeholder="e.g. Tommy, RACHEL...">
          </div>

          <%# Location %>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Location</label>
            <select data-dashboard-target="catchLocation"
                    required
                    class="w-full bg-gray-900 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm
                           focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none">
              <option value="">Select location...</option>
              <% @locations.each do |key, data| %>
                <option value="<%= key %>"><%= data['name'] %></option>
              <% end %>
            </select>
          </div>

          <%# Species %>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-1">Your Species</label>
            <input type="text" required autocomplete="off" list="pokedex-species"
                   data-dashboard-target="catchSpecies"
                   class="w-full bg-gray-900 border border-gray-600 rounded-lg px-3 py-2 text-white text-sm
                          focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none"
                   placeholder="Search species...">
            <datalist id="pokedex-species">
              <% @pokedex_species.each do |species| %>
                <option value="<%= species %>">
              <% end %>
            </datalist>
          </div>
        </div>

        <div class="flex items-center justify-between mt-6">
          <span data-dashboard-target="catchStatus" class="text-xs text-gray-500"></span>
          <div class="flex gap-2">
            <button type="button"
                    data-action="click->dashboard#closeCatchModal"
                    class="px-4 py-2 text-sm text-gray-400 hover:text-white transition">
              Cancel
            </button>
            <button type="submit"
                    class="px-4 py-2 text-sm bg-indigo-600 text-white rounded-lg hover:bg-indigo-500 transition font-medium">
              Catch!
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>
