<%# Run Roster sidebar — Tier 1 + Phase 1 in-game info from the active save
    slot. Renders one card per session in @run_sessions (typically 4). For
    OTHER players' cards we show the parsed metadata from their active save
    slot (each player still wants to see everyone else's progress). For YOU,
    the slot column on the LEFT shows your slots in detail — we omit the
    duplicate parsed info from the YOU card here. %>

<div class="gb-card" style="padding: 8px 10px; margin-bottom: 8px;">
  <div style="font-size: 11px; color: var(--d1); letter-spacing: 0.1em;">RUN ROSTER</div>
</div>

<% @run_sessions.each do |s| %>
  <% is_you = s.discord_user_id == current_user_id %>
  <%# Resolve the session's active slot (if any). For empty sessions or
      sessions whose `active_save_slot` is nil, this is nil — the card
      falls through to "Not started" semantics. %>
  <% active_slot = s.active_save_slot ? s.save_slots.find { |sl| sl.slot_number == s.active_save_slot } : nil %>
  <%# read_attribute_before_type_cast skips the gzip coder; the on-disk
      compressed bytes are what we want for the "save size" stat. %>
  <% saved_bytes = active_slot&.read_attribute_before_type_cast("save_data")&.bytesize %>
  <% player_label = if s.discord_user_id
                     SoulLink::GameState.player_name(s.discord_user_id).presence || s.discord_user_id.to_s
                   else
                     "Unclaimed"
                   end %>
  <%# Status palette: ready → green-on-dark (var(--l2) on var(--d1) — matches
      the existing "ACTIVE" badge in runs/index). pending/generating → amber.
      failed → gb-flash-alert palette. No new CSS classes. %>
  <% status_style = case s.status
                    when "ready"
                      "background: var(--d1); color: var(--l2); border: 2px solid var(--d1);"
                    when "pending", "generating"
                      "background: #d4b14a; color: var(--d1); border: 2px solid var(--d1);"
                    when "failed"
                      "background: #4a1c1c; color: #e8a0a0; border: 2px solid #6b2c2c;"
                    else
                      "background: var(--l2); color: var(--d1); border: 2px solid var(--d2);"
                    end %>

  <div class="gb-card" style="padding: 10px; margin-bottom: 8px;<%= ' border-width: 4px;' if is_you %>">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; gap: 6px;">
      <div style="font-size: 12px; color: var(--d1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
        <%= player_label %>
      </div>
      <% if is_you %>
        <span class="type-text" style="border-color: var(--d1); background: var(--d1); color: var(--l2); font-size: 9px;">YOU</span>
      <% end %>
    </div>

    <div style="margin-bottom: 6px;">
      <span class="type-text" style="<%= status_style %> font-size: 9px; letter-spacing: 0.05em;">
        <%= s.status.upcase %>
      </span>
    </div>

    <%# `updated_at` ticks every save → it's an "is this player active"
        signal. The parsed Time played field below is the in-game ground
        truth. Render save-presence + size on every card (it's lightweight
        and consistent with the prior layout). %>
    <% if saved_bytes && saved_bytes > 0 %>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
        Active <%= time_ago_in_words(active_slot.updated_at) %> ago
      </div>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
        Save: <%= number_to_human_size(saved_bytes) %>
      </div>
    <% else %>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">Not started</div>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">Save: &mdash;</div>
    <% end %>

    <%# Parsed in-game info renders for OTHER players (not YOU) — your own
        slot column on the left covers your detailed view. Other players'
        cards still need their progress visible here. %>
    <% if !is_you && active_slot&.parsed_trainer_name.present? %>
      <div style="font-size: 11px; color: var(--d1); margin-top: 6px; margin-bottom: 2px;">
        In-game: <%= active_slot.parsed_trainer_name %>
      </div>
    <% end %>

    <% if !is_you && active_slot&.parsed_play_seconds %>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
        Time played: <%= format_play_time(active_slot.parsed_play_seconds) %>
      </div>
    <% end %>

    <% if !is_you && active_slot&.parsed_money %>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
        Money: &#8369;<%= number_with_delimiter(active_slot.parsed_money) %>
      </div>
    <% end %>

    <%# Gate badges line on parsed_trainer_name (a strong signal of successful
        parse) rather than parsed_at (set on both success and failure paths).
        parsed_badges defaults to 0 in DB; without this gate, a failed parse
        renders "Badges: 0 / 8" indistinguishable from "successfully parsed,
        no badges yet". %>
    <% if !is_you && active_slot&.parsed_trainer_name.present? %>
      <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
        Badges: <%= active_slot.parsed_badges %> / 8
      </div>
    <% end %>

    <div style="font-size: 9px; color: var(--d2); opacity: 0.7; margin-top: 4px; word-break: break-all;">
      Seed: <%= s.seed %>
    </div>
  </div>
<% end %>
