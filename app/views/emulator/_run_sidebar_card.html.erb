<%# Single-session card for the run roster sidebar. Extracted from
    `_run_sidebar.html.erb` so the SoulLinkEmulatorSaveSlot model can
    re-render it via Turbo Stream broadcasts when parsed_* fields update.

    The partial takes a single local `s` (a SoulLinkEmulatorSession). It
    intentionally does NOT reference `current_user_id`, `@run_sessions`,
    or any other ivar — the broadcast renderer has no controller context.
    The YOU badge / 4px-border are rendered in the parent loop instead,
    so they survive across stream replacements (acceptable Known Gap:
    on a fresh broadcast, the YOU badge and 4px border momentarily
    disappear until the parent loop re-runs on next page load. See
    BUILD-LOG Known Gaps). %>

<% active_slot = s.active_save_slot ? s.save_slots.find { |sl| sl.slot_number == s.active_save_slot } : nil %>
<% saved_bytes = active_slot&.read_attribute_before_type_cast("save_data")&.bytesize %>
<% player_label = if s.discord_user_id
                   SoulLink::GameState.player_name(s.discord_user_id).presence || s.discord_user_id.to_s
                 else
                   "Unclaimed"
                 end %>
<% status_style = case s.status
                  when "ready"
                    "background: var(--d1); color: var(--l2); border: 2px solid var(--d1);"
                  when "pending", "generating"
                    "background: var(--amber); color: var(--d1); border: 2px solid var(--d1);"
                  when "failed"
                    "background: #4a1c1c; color: #e8a0a0; border: 2px solid #6b2c2c;"
                  else
                    "background: var(--l2); color: var(--d1); border: 2px solid var(--d2);"
                  end %>

<%# data-discord-user-id is read by roster_you_marker_controller.js to
    decorate the card matching the viewer's current_user_id with the YOU
    badge + 4px border. nil sessions render the attribute as empty
    string — matches no user, harmless. %>
<div class="gb-card" style="padding: 10px; margin-bottom: 8px;"
     data-discord-user-id="<%= s.discord_user_id %>">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; gap: 6px;">
    <div style="font-size: 12px; color: var(--d1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
      <%= player_label %>
    </div>
  </div>

  <div style="margin-bottom: 6px;">
    <span class="type-text" style="<%= status_style %> font-size: 9px; letter-spacing: 0.05em;">
      <%= s.status.upcase %>
    </span>
  </div>

  <% if saved_bytes && saved_bytes > 0 %>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
      Active <%= time_ago_in_words(active_slot.updated_at) %> ago
    </div>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
      Save: <%= number_to_human_size(saved_bytes) %>
    </div>
  <% else %>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">Not started</div>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">Save: &mdash;</div>
  <% end %>

  <%# Parsed in-game info — render unconditionally on the broadcast partial.
      The parent loop in _run_sidebar.html.erb is responsible for hiding
      these fields on the YOU card (see is_you gating outside the frame). %>
  <% if active_slot&.parsed_trainer_name.present? %>
    <div style="font-size: 11px; color: var(--d1); margin-top: 6px; margin-bottom: 2px;">
      In-game: <%= active_slot.parsed_trainer_name %>
    </div>
  <% end %>

  <% if active_slot&.parsed_play_seconds %>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
      Time played: <%= format_play_time(active_slot.parsed_play_seconds) %>
    </div>
  <% end %>

  <% if active_slot&.parsed_money %>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
      Money: &#8369;<%= number_with_delimiter(active_slot.parsed_money) %>
    </div>
  <% end %>

  <% if active_slot&.parsed_trainer_name.present? %>
    <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
      Badges: <%= active_slot.parsed_badges %> / 8
    </div>
  <% end %>

  <div style="font-size: 9px; color: var(--d2); opacity: 0.7; margin-top: 4px; word-break: break-all;">
    Seed: <%= s.seed %>
  </div>
</div>
