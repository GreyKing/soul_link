<%# Single-session card for the run roster sidebar. Step 21 R3 redesign.
    Extracted from `_run_sidebar.html.erb` so the SoulLinkEmulatorSaveSlot
    model can re-render it via Turbo Stream broadcasts when parsed_*
    fields update.

    The partial takes a single local `s` (a SoulLinkEmulatorSession). It
    intentionally does NOT reference `current_user_id`, `@run_sessions`,
    or any other ivar — the broadcast renderer has no controller context.
    The YOU badge / 4px-border are applied client-side by
    roster_you_marker_controller.js (which adds `.you` to the wrapper
    and injects a `.you-badge` span inside `.roster-card-name`). Same
    Known Gap as before: on a fresh broadcast, the YOU markers
    momentarily disappear until the controller re-runs.

    Step 21 R3 changes vs Step 16/17/18 layout:
    - Single `.head` row (name + state pill).
    - Three-tile stat strip: BADGES / DEX / PLAY.
    - TID conflict surfaces as a `.conflict-warning` band, not a pill.
    - Trainer / map / money / TID-SID / DEX-seen move inside <details>STATS.
    - Money symbol removed (no universal Pokédollar glyph).
    - Seed becomes click-to-copy via roster_seed_controller.js.
    - Active-ago + bytes rows dropped (logged as KG-34). %>

<% active_slot = s.active_save_slot ? s.save_slots.find { |sl| sl.slot_number == s.active_save_slot } : nil %>
<% player_label = if s.discord_user_id
                   SoulLink::GameState.player_name(s.discord_user_id).presence || s.discord_user_id.to_s
                 else
                   "Unclaimed"
                 end %>
<% status_pill_class = case s.status
                      when "ready"                  then "saved"
                      when "pending", "generating"  then "target"
                      when "failed"                 then "confirm"
                      else                                "saved"
                      end %>

<%# TID conflict — surface partner names when the lookup yields any
    real labels; otherwise fall back to a bare warning. %>
<% conflict_groups = s.soul_link_run.tid_conflict_groups %>
<% my_group = conflict_groups.find { |group| group.include?(s.id) } %>
<% partner_labels = if my_group.present?
                     other_ids = my_group - [ s.id ]
                     other_ids.filter_map do |id|
                       other = SoulLinkEmulatorSession.find_by(id: id)
                       next if other.nil? || other.discord_user_id.nil?
                       SoulLink::GameState.player_name(other.discord_user_id).presence
                     end
                   else
                     []
                   end %>
<% has_conflict = my_group.present? %>

<div class="roster-card" data-discord-user-id="<%= s.discord_user_id %>">
  <div class="head">
    <span class="name roster-card-name">
      <%= player_label %><% if active_slot&.parsed_hof_count.to_i >= 1 %><span class="hof-pill">🏆 HOF</span><% end %>
    </span>
    <span class="state-pill <%= status_pill_class %>"><%= s.status.upcase %></span>
  </div>

  <div class="stats">
    <div class="stat">
      <div class="lbl">BADGES</div>
      <div class="val"><%= active_slot&.parsed_badges.nil? ? "—" : active_slot.parsed_badges %></div>
    </div>
    <div class="stat">
      <div class="lbl">DEX</div>
      <div class="val"><%= active_slot&.parsed_pokedex_caught.nil? ? "—" : active_slot.parsed_pokedex_caught %></div>
    </div>
    <div class="stat">
      <div class="lbl">PLAY</div>
      <div class="val"><%= format_play_time(active_slot&.parsed_play_seconds) %></div>
    </div>
  </div>

  <% if has_conflict %>
    <div class="conflict-warning">
      <% if partner_labels.any? %>
        ⚠ TID CONFLICT WITH <%= partner_labels.join(", ") %> · re-roll the seed
      <% else %>
        ⚠ TID CONFLICT · re-roll the seed
      <% end %>
    </div>
  <% end %>

  <details>
    <summary>STATS</summary>
    <div class="extra">
      <% if active_slot&.parsed_trainer_name.present? %>
        <div class="row"><span class="lbl">TRAINER</span><span><%= active_slot.parsed_trainer_name %></span></div>
      <% end %>

      <% if active_slot&.parsed_map_id %>
        <div class="row"><span class="lbl">MAP</span><span><%= format_map_name(active_slot.parsed_map_id) %></span></div>
      <% end %>

      <% if active_slot&.parsed_money %>
        <div class="row"><span class="lbl">MONEY</span><span><%= number_with_delimiter(active_slot.parsed_money) %></span></div>
      <% end %>

      <% if active_slot&.parsed_trainer_id.to_i.positive? %>
        <div class="row"><span class="lbl">TID/SID</span><span><%= active_slot.parsed_trainer_id %>/<%= active_slot.parsed_secret_id %></span></div>
      <% end %>

      <% if active_slot&.parsed_pokedex_seen %>
        <div class="row"><span class="lbl">DEX SEEN</span><span><%= active_slot.parsed_pokedex_seen %></span></div>
      <% end %>

      <%# Click-to-copy seed. roster_seed_controller.js handles the
          clipboard write + the brief "Copied!" feedback. CSS owns the
          hover hint. %>
      <div class="seed"
           data-controller="roster-seed"
           data-action="click->roster-seed#copy">Seed: <%= s.seed %></div>
    </div>
  </details>
</div>
