<%# Save slots sidebar — left column on /emulator. Step 21 R3 redesign.
    Renders the player's own 5 save slots (1..5). Every slot shows a
    state pill (EMPTY/SAVED/ACTIVE/TARGET/CONFIRM). Filled slots show
    parsed in-game metadata + per-slot actions (DOWNLOAD, MAKE ACTIVE,
    DELETE). DELETE and CLEAR ALL SLOTS use inline confirmation
    (no modal); the inline `.confirm-inline` block is rendered hidden
    server-side and revealed by save_slots_controller.js.

    Overwrite-pending mode: when all 5 slots are full and the user
    clicks "Save File" in the emulator UI, the column enters TARGET
    mode — sticky banner appears at top, every filled slot becomes a
    click-target with the amber TARGET pill. Cancel via the banner.

    `@save_slots` is preloaded by EmulatorController#show in slot_number
    order. `@session.active_save_slot` (or nil) is the active pointer;
    serving `/emulator/save_data` GET reads from this slot. %>

<% slots_by_number = @save_slots.index_by(&:slot_number) %>

<div data-controller="save-slots"
     data-save-slots-slots-url-value="<%= emulator_save_slots_path %>"
     data-save-slots-csrf-value="<%= form_authenticity_token %>"
     data-save-slots-active-value="<%= @session.active_save_slot.to_s %>">

  <h2 style="font-family: 'Press Start 2P', monospace; font-size: 11px; color: var(--white); margin: 0 0 10px; letter-spacing: 1px;">SAVE SLOTS</h2>

  <%# Pending banner — revealed by save_slots_controller.js when the
      column enters overwrite-pending mode (after a 409 response). The
      CANCEL button exits the mode without writing anything. %>
  <div data-save-slots-target="banner" hidden class="pending-banner">
    <span class="icon">⚠</span>
    SAVE FULL — PICK A SLOT TO OVERWRITE
    <button type="button" data-action="click->save-slots#cancelOverwrite">CANCEL</button>
  </div>

  <% (SoulLinkEmulatorSaveSlot::MIN_SLOT..SoulLinkEmulatorSaveSlot::MAX_SLOT).each do |n| %>
    <% slot = slots_by_number[n] %>
    <% is_active = @session.active_save_slot == n %>
    <% pill_class = if slot.nil?
                     "empty"
                   elsif is_active
                     "active"
                   else
                     "saved"
                   end %>
    <% pill_text = pill_class.upcase %>

    <div class="slot<%= ' active' if is_active %><%= ' empty' if slot.nil? %>"
         data-save-slots-target="slot"
         data-slot-number="<%= n %>"
         data-filled="<%= !slot.nil? %>">

      <div class="slot-head">
        <span class="slot-num">SLOT <%= n %></span>
        <span class="state-pill <%= pill_class %>" data-save-slots-target="slotPill"><%= pill_text %></span>
      </div>

      <% if slot.nil? %>
        <div class="slot-meta">— drop a save here from the emulator —</div>
      <% else %>
        <div class="slot-meta">
          <% if slot.parsed_trainer_name.present? %>
            <strong><%= slot.parsed_trainer_name %></strong>
          <% end %>

          <% play_present = slot.parsed_play_seconds.present? %>
          <% badges_present = slot.parsed_trainer_name.present? %>
          <% if play_present || badges_present %>
            <div class="row">
              <% if play_present %>
                <span class="lbl">PLAY</span> <span class="val"><%= format_play_time(slot.parsed_play_seconds) %></span>
              <% end %>
              <% if badges_present %>
                <span class="lbl">BADGES</span> <span class="val"><%= slot.parsed_badges.to_i %> / 8</span>
              <% end %>
            </div>
          <% end %>

          <% if slot.parsed_map_id %>
            <div class="row">
              <span class="lbl">MAP</span> <span class="val"><%= format_map_name(slot.parsed_map_id) %></span>
            </div>
          <% end %>

          <% if slot.parsed_pokedex_caught || slot.parsed_pokedex_seen %>
            <div class="row">
              <span class="lbl">DEX</span>
              <span class="val"><%= slot.parsed_pokedex_caught || 0 %> caught · <%= slot.parsed_pokedex_seen || 0 %> seen</span>
            </div>
          <% end %>

          <%# Step 16: TID/SID — same render rule as the run-roster card.
              No conflict pill on the player's own slots. %>
          <% if slot.parsed_trainer_id.to_i.positive? %>
            <div class="row">
              <span class="lbl">TID/SID</span>
              <span class="val"><%= slot.parsed_trainer_id %> / <%= slot.parsed_secret_id %></span>
            </div>
          <% end %>
        </div>

        <%# HOF pill — kept on the slot card per Ava's answer #4. Renders
            after the body rows, before .slot-actions. %>
        <% if slot.parsed_hof_count.to_i >= 1 %>
          <div style="margin-top: 6px;">
            <span class="hof-pill">🏆 HOF</span>
          </div>
        <% end %>

        <%# Per-slot action row. Hidden by save_slots_controller.js
            during TARGET mode and during inline DELETE confirm. %>
        <div class="slot-actions" data-save-slots-target="actionRow">
          <a href="<%= download_emulator_save_slot_path(slot_number: n) %>">DOWNLOAD</a>
          <% unless is_active %>
            <button type="button"
                    class="primary"
                    data-action="click->save-slots#makeActive"
                    data-slot-number="<%= n %>">
              MAKE ACTIVE
            </button>
          <% end %>
          <button type="button"
                  class="danger"
                  data-action="click->save-slots#confirmDelete"
                  data-slot-number="<%= n %>">
            DELETE
          </button>
        </div>

        <%# Inline DELETE confirm — rendered hidden, revealed by
            save_slots_controller.js#confirmDelete. The DELETE FOREVER
            button fires the existing save-slots#deleteSlot. %>
        <div class="confirm-inline" hidden data-save-slots-target="confirmRow" data-slot-number="<%= n %>">
          <div class="q">DELETE THIS SLOT?</div>
          <div class="body"><%= format_progress_phrase(slot.parsed_play_seconds) %>. There's no undo — the save file is gone after this.</div>
          <div class="actions">
            <button type="button"
                    data-action="click->save-slots#cancelDelete"
                    data-slot-number="<%= n %>">CANCEL</button>
            <button type="button"
                    class="confirm"
                    data-action="click->save-slots#deleteSlot"
                    data-slot-number="<%= n %>">DELETE FOREVER</button>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# CLEAR ALL SLOTS footer — wipes every slot via the existing
      clear-save controller. Inline confirm: clicking the trigger
      reveals a sibling confirm block; the confirm button fires
      clear-save#clear. %>
  <% if @save_slots.any? %>
    <div data-controller="clear-save"
         data-clear-save-url-value="<%= save_data_emulator_path %>"
         data-clear-save-csrf-value="<%= form_authenticity_token %>">
      <div class="footer-actions" data-save-slots-target="clearAllAction">
        <button type="button" data-action="click->save-slots#confirmClearAll">CLEAR ALL SLOTS</button>
      </div>
      <div class="confirm-inline" hidden data-save-slots-target="clearAllConfirm">
        <div class="q">CLEAR EVERY SAVE?</div>
        <div class="body">This wipes all <%= @save_slots.size %> save slots at once. There is no undo for any of them.</div>
        <div class="actions">
          <button type="button" data-action="click->save-slots#cancelClearAll">CANCEL</button>
          <button type="button" class="confirm" data-action="click->clear-save#clear">CLEAR ALL SLOTS</button>
        </div>
      </div>
    </div>
  <% end %>
</div>
