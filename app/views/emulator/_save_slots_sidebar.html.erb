<%# Save slots sidebar — left column on /emulator. Renders the player's
    own 5 save slots (1..5). Filled slots show parsed in-game metadata plus
    per-slot actions (Download, Make Active, Delete). Empty slots show
    "Empty". When all 5 are full and the user clicks "Save File" in the
    emulator UI, the page enters overwrite-pending mode and each card
    becomes a click-target that overwrites that slot.

    `@save_slots` is preloaded by EmulatorController#show in slot_number
    order. `@session.active_save_slot` (or nil) is the active pointer;
    serving `/emulator/save_data` GET reads from this slot. %>

<% slots_by_number = @save_slots.index_by(&:slot_number) %>

<div data-controller="save-slots"
     data-save-slots-slots-url-value="<%= emulator_save_slots_path %>"
     data-save-slots-csrf-value="<%= form_authenticity_token %>"
     data-save-slots-active-value="<%= @session.active_save_slot.to_s %>">

  <div class="gb-card" style="padding: 8px 10px; margin-bottom: 8px;">
    <div style="font-size: 11px; color: var(--d1); letter-spacing: 0.1em;">SAVE SLOTS</div>
  </div>

  <%# Banner — shown only when overwrite-pending mode is active (set by the
      Stimulus controller after a 409 response). data-save-slots-target=
      "banner" + the `hidden` class flip is the only behavior here. %>
  <div data-save-slots-target="banner"
       hidden
       class="gb-card"
       style="padding: 8px 10px; margin-bottom: 8px; background: #4a3a1c; color: #e8d6a0; border: 2px solid #6b5a2c;">
    <div style="font-size: 10px; line-height: 1.4;">
      All slots full. Click a slot below to overwrite it with the save you just made.
    </div>
  </div>

  <% (SoulLinkEmulatorSaveSlot::MIN_SLOT..SoulLinkEmulatorSaveSlot::MAX_SLOT).each do |n| %>
    <% slot = slots_by_number[n] %>
    <% is_active = @session.active_save_slot == n %>
    <% saved_bytes = slot&.read_attribute_before_type_cast("save_data")&.bytesize %>

    <div class="gb-card"
         data-save-slots-target="slot"
         data-slot-number="<%= n %>"
         data-filled="<%= !slot.nil? %>"
         style="padding: 10px; margin-bottom: 8px; position: relative;<%= ' border-width: 4px;' if is_active %>">

      <%# Click overlay — only visible in overwrite-pending mode. The
          Stimulus controller toggles `hidden` on this element. Clicking
          triggers the overwrite PATCH for this slot. %>
      <button type="button"
              data-save-slots-target="overwriteOverlay"
              data-action="click->save-slots#overwriteSlot"
              data-slot-number="<%= n %>"
              hidden
              class="type-text"
              style="position: absolute; inset: 0; width: 100%; height: 100%; background: rgba(74, 58, 28, 0.85); color: #e8d6a0; border: 2px solid #6b5a2c; font-size: 11px; letter-spacing: 0.05em; cursor: pointer; z-index: 5;">
        CLICK TO OVERWRITE SLOT <%= n %>
      </button>

      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; gap: 6px;">
        <div style="font-size: 12px; color: var(--d1);">
          SLOT <%= n %>
        </div>
        <% if is_active %>
          <span class="type-text" style="border-color: var(--d1); background: var(--d1); color: var(--l2); font-size: 9px;">ACTIVE</span>
        <% end %>
      </div>

      <% if slot.nil? %>
        <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">Empty</div>
      <% else %>
        <% if slot.parsed_trainer_name.present? %>
          <div style="font-size: 11px; color: var(--d1); margin-bottom: 2px;">
            <%= slot.parsed_trainer_name %>
          </div>
        <% end %>

        <% if slot.parsed_play_seconds %>
          <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
            Time: <%= format_play_time(slot.parsed_play_seconds) %>
          </div>
        <% end %>

        <% if slot.parsed_money %>
          <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
            Money: &#8369;<%= number_with_delimiter(slot.parsed_money) %>
          </div>
        <% end %>

        <% if slot.parsed_map_id %>
          <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
            Map: <%= format_map_name(slot.parsed_map_id) %>
          </div>
        <% end %>

        <% if slot.parsed_trainer_name.present? %>
          <div style="font-size: 10px; color: var(--d2); line-height: 1.6;">
            Badges: <%= slot.parsed_badges %> / 8
          </div>
        <% end %>

        <% if saved_bytes && saved_bytes > 0 %>
          <div style="font-size: 9px; color: var(--d2); opacity: 0.7; line-height: 1.6;">
            <%= number_to_human_size(saved_bytes) %> &middot; saved <%= time_ago_in_words(slot.updated_at) %> ago
          </div>
        <% end %>

        <%# Per-slot actions. Download is a plain <a> (let the browser
            handle attachment headers); Make Active and Delete are buttons
            that the Stimulus controller intercepts. %>
        <div style="display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px;">
          <a href="<%= download_emulator_save_slot_path(slot_number: n) %>"
             class="type-text"
             style="background: var(--l2); color: var(--d1); border: 2px solid var(--d1); font-size: 9px; letter-spacing: 0.05em; padding: 3px 6px; text-decoration: none; flex: 1; text-align: center;">
            DOWNLOAD
          </a>
          <% unless is_active %>
            <button type="button"
                    data-action="click->save-slots#makeActive"
                    data-slot-number="<%= n %>"
                    class="type-text"
                    style="background: var(--l2); color: var(--d1); border: 2px solid var(--d1); font-size: 9px; letter-spacing: 0.05em; cursor: pointer; padding: 3px 6px; flex: 1;">
              MAKE ACTIVE
            </button>
          <% end %>
          <button type="button"
                  data-action="click->save-slots#deleteSlot"
                  data-slot-number="<%= n %>"
                  class="type-text"
                  style="background: #4a1c1c; color: #e8a0a0; border: 2px solid #6b2c2c; font-size: 9px; letter-spacing: 0.05em; cursor: pointer; padding: 3px 6px; flex: 1;">
            DELETE
          </button>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Clear-all button — wipes every slot. Lives at the bottom of the
      column. Reuses the existing clear-save Stimulus controller, which
      DELETEs /emulator/save_data (server now wipes all slots). %>
  <% if @save_slots.any? %>
    <div data-controller="clear-save"
         data-clear-save-url-value="<%= save_data_emulator_path %>"
         data-clear-save-csrf-value="<%= form_authenticity_token %>"
         style="margin-top: 16px;">
      <button type="button"
              data-action="click->clear-save#clear"
              class="type-text"
              style="background: #4a1c1c; color: #e8a0a0; border: 2px solid #6b2c2c; font-size: 9px; letter-spacing: 0.05em; cursor: pointer; width: 100%; padding: 6px 8px;">
        CLEAR ALL SLOTS
      </button>
    </div>
  <% end %>
</div>
