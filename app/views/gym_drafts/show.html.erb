<div style="margin-bottom: 16px;">
  <div class="gb-page-title">GYM DRAFT</div>
  <div class="gb-page-subtitle">Collaboratively pick your team for the next gym.</div>
</div>

<div data-controller="gym-draft"
     data-gym-draft-draft-id-value="<%= @draft.id %>"
     data-gym-draft-user-id-value="<%= current_user_id %>"
     data-gym-draft-players-value="<%= @players.map { |p| p.merge('discord_user_id' => p['discord_user_id'].to_s) }.to_json %>"
     data-gym-draft-player-groups-value="<%= @player_groups.transform_keys(&:to_s).transform_values { |groups|
       groups.map { |g|
         {
           id: g.id,
           nickname: g.nickname,
           location: g.location,
           pokemon: g.soul_link_pokemon.map { |p| { species: p.species, discord_user_id: p.discord_user_id.to_s } }
         }
       }
     }.to_json %>">

  <%# ── STATUS BAR ── %>
  <div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
    <span data-gym-draft-target="phaseLabel"
          class="type-text" style="background: var(--d2); color: var(--l2); border-color: var(--d1);">
      <%= @draft.status.upcase %>
    </span>
    <span data-gym-draft-target="phaseInfo" style="font-size: 10px; color: var(--d2);"></span>
  </div>

  <%# ── LOBBY PHASE ── %>
  <div data-gym-draft-target="lobbyPanel">
    <div class="gb-card" style="max-width: 480px; margin: 0 auto; text-align: center; padding: 16px;">
      <div style="font-size: 14px; margin-bottom: 12px;">WAITING FOR PLAYERS</div>
      <div class="gb-grid-2" style="margin-bottom: 16px;" data-gym-draft-target="readyGrid">
        <% @players.each do |player| %>
          <div class="gb-card-dark" style="text-align: center; padding: 10px;"
               data-player-id="<%= player['discord_user_id'].to_s %>">
            <div style="font-size: 11px; color: var(--l2);"><%= player['display_name'] %></div>
            <div class="ready-status" style="font-size: 10px; color: var(--l1); margin-top: 4px;">Not ready</div>
          </div>
        <% end %>
      </div>
      <button type="button"
              data-action="click->gym-draft#ready"
              data-gym-draft-target="readyButton"
              class="gb-btn-primary">
        READY
      </button>
    </div>
  </div>

  <%# ── VOTING PHASE ── %>
  <div data-gym-draft-target="votingPanel" class="hidden">
    <div class="gb-card" style="max-width: 480px; margin: 0 auto; text-align: center; padding: 16px;">
      <div style="font-size: 14px; margin-bottom: 4px;">VOTE FOR FIRST PICK</div>
      <div style="font-size: 10px; color: var(--d2); margin-bottom: 12px;">Who should choose first?</div>
      <div class="gb-grid-2" data-gym-draft-target="voteGrid">
        <% @players.each do |player| %>
          <button type="button"
                  data-action="click->gym-draft#vote"
                  data-vote-for="<%= player['discord_user_id'].to_s %>"
                  class="gb-btn" style="padding: 12px; text-align: center;">
            <div style="font-size: 11px;"><%= player['display_name'] %></div>
          </button>
        <% end %>
      </div>
      <div data-gym-draft-target="voteStatus" style="font-size: 10px; color: var(--d2); margin-top: 10px;"></div>
    </div>
  </div>

  <%# ── DRAFTING PHASE ── %>
  <div data-gym-draft-target="draftingPanel" class="hidden">
    <div class="gb-card" style="padding: 16px; margin-bottom: 12px;">
      <div style="font-size: 13px; text-align: center; margin-bottom: 12px;">TEAM SLOTS</div>
      <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px;" data-gym-draft-target="teamSlots">
        <% 6.times do |i| %>
          <div class="gb-drag-zone" style="text-align: center; min-height: 70px; display: flex; align-items: center; justify-content: center;"
               data-slot-index="<%= i %>">
            <span style="font-size: 10px; color: var(--d2);">#<%= i + 1 %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div style="text-align: center; margin-bottom: 12px;">
      <span data-gym-draft-target="turnIndicator" style="font-size: 11px; color: var(--d1);"></span>
    </div>

    <div class="gb-card" style="padding: 10px;">
      <div style="font-size: 11px; color: var(--d2); margin-bottom: 8px;">YOUR CAUGHT POKEMON</div>
      <div class="gb-grid-4" data-gym-draft-target="myPokemonGrid">
      </div>
    </div>
  </div>

  <%# ── NOMINATING PHASE ── %>
  <div data-gym-draft-target="nominatingPanel" class="hidden">
    <div class="gb-card" style="padding: 16px; margin-bottom: 12px;">
      <div style="font-size: 13px; text-align: center; margin-bottom: 12px;">TEAM SLOTS</div>
      <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px;" data-gym-draft-target="nomTeamSlots">
        <% 6.times do |i| %>
          <div class="gb-drag-zone" style="text-align: center; min-height: 70px; display: flex; align-items: center; justify-content: center;"
               data-slot-index="<%= i %>">
            <span style="font-size: 10px; color: var(--d2);">#<%= i + 1 %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div style="text-align: center; margin-bottom: 12px;">
      <span data-gym-draft-target="nomStatus" style="font-size: 11px; color: var(--d1);"></span>
    </div>

    <div data-gym-draft-target="nomVoteArea" class="hidden" style="text-align: center; margin-bottom: 12px;">
      <div data-gym-draft-target="nomVotePrompt" style="font-size: 11px; margin-bottom: 8px;"></div>
      <div style="display: flex; justify-content: center; gap: 8px;">
        <button type="button"
                data-action="click->gym-draft#approveNomination"
                class="gb-btn-primary gb-btn-sm">
          AGREE
        </button>
        <button type="button"
                data-action="click->gym-draft#rejectNomination"
                class="gb-btn-danger gb-btn-sm">
          DISAGREE
        </button>
      </div>
    </div>

    <div class="gb-card" style="padding: 10px;">
      <div style="font-size: 11px; color: var(--d2); margin-bottom: 8px;">NOMINATE A POKEMON (click to nominate)</div>
      <div class="gb-grid-4" data-gym-draft-target="nomPokemonGrid">
      </div>
    </div>
  </div>

  <%# ── COMPLETE PHASE ── %>
  <div data-gym-draft-target="completePanel" class="hidden">
    <div class="gb-card" style="padding: 16px;">
      <div style="font-size: 14px; text-align: center; margin-bottom: 4px;">DRAFT COMPLETE!</div>
      <div style="font-size: 10px; color: var(--d2); text-align: center; margin-bottom: 16px;">Here's your recommended team composition.</div>

      <div style="display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; margin-bottom: 16px;" data-gym-draft-target="finalTeamSlots">
        <% 6.times do |i| %>
          <div class="gb-card-dark" style="text-align: center; min-height: 70px; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 8px;"
               data-slot-index="<%= i %>">
            <span style="font-size: 10px; color: var(--l1);">#<%= i + 1 %></span>
          </div>
        <% end %>
      </div>

      <div style="text-align: center;">
        <%= link_to "BACK TO GYM READY", gym_ready_path, class: "gb-btn-primary" %>
      </div>
    </div>
  </div>
</div>
