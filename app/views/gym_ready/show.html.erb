<%# ── HEADER ── %>
<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
  <div>
    <div class="gb-page-title">GYM READY CHECK</div>
    <div class="gb-page-subtitle"><%= @player_name %>'s team readiness analysis.</div>
  </div>
  <%= button_to "START GYM DRAFT", gym_drafts_path, method: :post, class: "gb-btn-primary gb-btn-sm" %>
</div>

<%# ── NEXT GYM INFO ── %>
<% if @next_gym %>
  <div class="gb-card-dark" style="display: flex; align-items: center; gap: 12px; padding: 12px; margin-bottom: 16px;">
    <div style="width: 48px; height: 48px; border: var(--border); background: var(--d1); display: flex; align-items: center; justify-content: center; font-size: 18px; color: var(--l2); flex-shrink: 0;">
      <%= @next_gym['number'] %>
    </div>
    <div>
      <div style="font-size: 14px; color: var(--l2);"><%= @next_gym['name'].upcase %></div>
      <div style="font-size: 10px; color: var(--l1); margin-top: 2px;">
        Leader: <%= @next_gym['leader'] %> &mdash; Type: <%= pixeldex_type_badge(@next_gym['type']) %>
      </div>
      <div style="font-size: 10px; color: var(--l2); margin-top: 2px;">Level Cap: <%= @next_gym['max_level'] %></div>
    </div>
  </div>
<% else %>
  <div class="gb-card-dark" style="padding: 12px; margin-bottom: 16px;">
    <div style="font-size: 11px; color: var(--l2);">All 8 badges earned! Prepare for the Elite Four.</div>
  </div>
<% end %>

<%# ── YOUR TEAM ── %>
<div style="margin-bottom: 16px;">
  <div class="gb-section-header">YOUR TEAM</div>
  <% if @team_groups.any? %>
    <div class="gb-grid-3">
      <% @team_groups.each_with_index do |group, idx| %>
        <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
        <% is_dead = group.dead? %>
        <div class="<%= is_dead ? 'gb-card gb-status-dead' : 'gb-card' %>" style="padding: 8px;">
          <div style="display: flex; align-items: center; gap: 6px;">
            <span style="font-size: 10px; color: var(--d2); width: 16px;">#<%= idx + 1 %></span>
            <% if my_pokemon %>
              <div style="<%= is_dead ? 'opacity: 0.4;' : '' %>">
                <%= pokemon_sprite_tag(my_pokemon.species, size: 32) %>
              </div>
              <div>
                <div style="font-size: 11px; <%= is_dead ? 'text-decoration: line-through; color: #e8a0a0;' : '' %>"><%= my_pokemon.species %></div>
                <% if is_dead %>
                  <div style="font-size: 9px; color: #e8a0a0; margin-top: 2px;">Dead</div>
                <% else %>
                  <div style="margin-top: 2px;"><%= pixeldex_type_badges(my_pokemon.species) %></div>
                <% end %>
              </div>
            <% else %>
              <span style="font-size: 10px; color: var(--d2);">No species assigned</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="gb-card" style="font-size: 10px; color: var(--d2); padding: 16px;">
      No team built yet. Visit <a href="<%= team_path %>" class="gb-link">My Team</a> to build one.
    </div>
  <% end %>
</div>

<%# ── TYPE ANALYSIS ── %>
<% if @player_pokemon.any? %>
  <div class="gb-grid-2" style="margin-bottom: 16px;">
    <%# Offensive coverage %>
    <div class="gb-card" style="padding: 10px;">
      <div style="font-size: 12px; margin-bottom: 4px;">OFFENSIVE COVERAGE</div>
      <div style="font-size: 9px; color: var(--d2); margin-bottom: 8px;">Types your team can hit super effectively.</div>

      <% if @type_analysis[:offensive_coverage].any? %>
        <div style="margin-bottom: 8px;">
          <% @type_analysis[:offensive_coverage].each do |type_name| %>
            <%= pixeldex_type_badge(type_name) %>
          <% end %>
        </div>
      <% end %>

      <% if @type_analysis[:offensive_gaps].any? %>
        <div style="font-size: 9px; margin-bottom: 4px;">Gaps:</div>
        <span class="type-coverage-gap">
          <% @type_analysis[:offensive_gaps].each do |type_name| %>
            <%= pixeldex_type_badge(type_name) %>
          <% end %>
        </span>
      <% else %>
        <div style="font-size: 10px; color: var(--d2);">Full offensive coverage!</div>
      <% end %>
    </div>

    <%# Shared weaknesses %>
    <div class="gb-card" style="padding: 10px;">
      <div style="font-size: 12px; margin-bottom: 4px;">SHARED WEAKNESSES</div>
      <div style="font-size: 9px; color: var(--d2); margin-bottom: 8px;">Types multiple members are weak to.</div>

      <% if @type_analysis[:shared_weaknesses].any? %>
        <% @type_analysis[:shared_weaknesses].each do |entry| %>
          <div class="stat-row">
            <span><%= pixeldex_type_badge(entry[:type]) %></span>
            <span class="stat-val" style="font-size: 11px;">
              <%= entry[:count] %>/<%= @player_pokemon.size %>
              <% if entry[:count] >= (@player_pokemon.size / 2.0).ceil %>
                !
              <% end %>
            </span>
          </div>
        <% end %>
      <% else %>
        <div style="font-size: 10px; color: var(--d2);">No shared type weaknesses!</div>
      <% end %>
    </div>
  </div>

  <%# Type distribution + balance notes %>
  <div class="gb-card" style="padding: 10px; margin-bottom: 16px;">
    <div style="font-size: 12px; margin-bottom: 8px;">TYPE DISTRIBUTION</div>
    <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px;">
      <% @type_analysis[:type_distribution].each do |entry| %>
        <span><%= pixeldex_type_badge(entry[:type]) %> <span style="font-size: 10px; color: var(--d2);">&times;<%= entry[:count] %></span></span>
      <% end %>
    </div>

    <% if @type_analysis[:balance_notes].any? %>
      <div style="border-top: var(--border-thin); padding-top: 8px; margin-top: 8px;">
        <% @type_analysis[:balance_notes].each do |note| %>
          <div style="font-size: 10px; color: var(--d2); margin-bottom: 4px;">
            <%= note[:level] == :warning ? '! ' : '+ ' %><%= note[:message] %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── AVAILABLE ROUTES ── %>
<div>
  <div class="gb-section-header">AVAILABLE ROUTES</div>
  <div style="font-size: 9px; color: var(--d2); margin-bottom: 8px;">All encounter locations through the current segment.</div>

  <% if @segments.any? %>
    <% @segments.each_with_index do |segment, seg_idx| %>
      <% gym_key = segment['gym'] %>
      <% gym = gym_key ? @gym_info[gym_key] : nil %>

      <div class="gb-card" style="padding: 10px; margin-bottom: 8px;">
        <div style="font-size: 11px; margin-bottom: 8px;">
          <% if gym %>
            <% beaten = @gyms_defeated >= gym['number'] %>
            SEGMENT <%= seg_idx + 1 %> &mdash;
            <span style="<%= beaten ? 'color: var(--d1);' : 'color: var(--d2);' %>"><%= gym['name'].upcase %></span>
            <% if beaten %>
              &#9733;
            <% end %>
          <% else %>
            SEGMENT <%= seg_idx + 1 %>
          <% end %>
        </div>

        <div class="gb-grid-4">
          <% (segment['locations'] || []).each do |loc_key| %>
            <% loc_data = @locations[loc_key] %>
            <% next unless loc_data %>
            <% groups = @groups_by_location[loc_key] %>
            <% group = groups&.first %>
            <% is_dead = group&.dead? %>
            <% is_caught = group&.caught? %>
            <% has_encounter = group.present? %>

            <div class="<%= is_dead ? 'gb-status-dead' : '' %>" style="border: var(--border-thin); padding: 6px; font-size: 10px;
                        <%= if is_dead then 'background: #4a1c1c; border-color: #6b2c2c;'
                            elsif is_caught then 'background: var(--d2); color: var(--l2);'
                            else 'background: var(--l1);'
                            end %>">
              <div style="<%= is_dead ? 'color: #e8a0a0;' : is_caught ? 'color: var(--l2);' : 'color: var(--d2);' %>">
                <%= loc_data['name'] %>
              </div>
              <% if has_encounter %>
                <div style="font-size: 9px; margin-top: 2px; <%= is_dead ? 'color: #e8a0a0;' : 'color: var(--l1);' %>">
                  <%= "\u{1F480} " if is_dead %><%= group.nickname %>
                </div>
                <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == current_user_id } %>
                <% if my_pokemon %>
                  <div style="margin-top: 2px; display: flex; align-items: center; gap: 2px; <%= is_dead ? 'opacity: 0.5;' : '' %>">
                    <%= pokemon_sprite_tag(my_pokemon.species, size: 16) %>
                    <span style="font-size: 9px; <%= is_dead ? 'text-decoration: line-through;' : '' %>"><%= my_pokemon.species %></span>
                  </div>
                <% end %>
              <% else %>
                <div style="font-size: 9px; color: var(--d2); margin-top: 2px;">No catch</div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="gb-card" style="font-size: 10px; color: var(--d2); text-align: center; padding: 16px;">
      No progression data available.
    </div>
  <% end %>
</div>
