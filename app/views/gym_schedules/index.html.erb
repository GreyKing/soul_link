<div style="margin-bottom: 16px;">
  <div class="gb-page-title">GYM SCHEDULES</div>
  <div class="gb-page-subtitle">Propose a time for the next gym battle and RSVP.</div>
</div>

<%# ── Create New Schedule ── %>
<% unless @schedules.any? %>
  <div class="gb-card" style="max-width: 500px; padding: 16px; margin-bottom: 16px;">
    <div style="font-size: 12px; margin-bottom: 12px;">PROPOSE A GYM DAY</div>
    <%= form_with url: gym_schedules_path, method: :post, style: "display: flex; flex-wrap: wrap; gap: 8px; align-items: flex-end;" do |f| %>
      <div style="flex: 1; min-width: 200px;">
        <label for="scheduled_at" class="gb-label">WHEN?</label>
        <input type="datetime-local" name="scheduled_at" id="scheduled_at" required class="gb-input">
      </div>
      <button type="submit" class="gb-btn-primary gb-btn-sm">PROPOSE</button>
    <% end %>
  </div>
<% end %>

<%# ── Upcoming / Active Schedules ── %>
<% if @schedules.any? %>
  <div style="margin-bottom: 20px;">
    <div class="gb-section-header">UPCOMING</div>
    <% @schedules.each do |schedule| %>
      <%= link_to gym_schedule_path(schedule), style: "text-decoration: none; color: inherit; display: block;" do %>
        <div class="gb-card" style="padding: 10px; cursor: pointer;">
          <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px;">
            <div>
              <div style="font-size: 12px;"><%= schedule.scheduled_at.strftime("%A, %B %-d at %-I:%M %p") %></div>
              <div style="font-size: 10px; color: var(--d2); margin-top: 2px;">
                Proposed by <%= schedule.proposer_name %>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 8px; font-size: 10px;">
              <span style="color: var(--d1);"><%= schedule.yes_count %> yes</span>
              <% if schedule.maybe_count > 0 %>
                <span style="color: var(--d2);"><%= schedule.maybe_count %> maybe</span>
              <% end %>
              <% if schedule.no_count > 0 %>
                <span style="color: var(--d2);"><%= schedule.no_count %> no</span>
              <% end %>
              <span class="type-text" style="<%= schedule.confirmed? ? 'background: var(--d2); color: var(--l2); border-color: var(--d1);' : '' %>">
                <%= schedule.status.upcase %>
              </span>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<%# ── Past Schedules ── %>
<% if @past_schedules.any? %>
  <div>
    <div class="gb-section-header">PAST</div>
    <% @past_schedules.each do |schedule| %>
      <div class="gb-card" style="opacity: 0.5; padding: 8px;">
        <div style="display: flex; align-items: center; justify-content: space-between; font-size: 10px;">
          <div style="color: var(--d2);">
            <%= schedule.scheduled_at.strftime("%B %-d at %-I:%M %p") %>
            <span style="margin-left: 6px;">&mdash; <%= schedule.proposer_name %></span>
          </div>
          <span class="type-text"><%= schedule.status.upcase %></span>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
