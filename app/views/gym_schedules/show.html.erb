<div style="margin-bottom: 16px; display: flex; align-items: center; justify-content: space-between;">
  <div>
    <div class="gb-page-title">GYM SCHEDULE</div>
    <div class="gb-page-subtitle"><%= @schedule.scheduled_at.strftime("%A, %B %-d at %-I:%M %p") %></div>
  </div>
  <%= link_to "ALL SCHEDULES", gym_schedules_path, class: "gb-nav-link" %>
</div>

<div data-controller="gym-schedule"
     data-gym-schedule-schedule-id-value="<%= @schedule.id %>"
     data-gym-schedule-user-id-value="<%= current_user_id %>"
     data-gym-schedule-players-value="<%= @players.map { |p| p.merge('discord_user_id' => p['discord_user_id'].to_s) }.to_json %>">

  <%# ── Status Bar ── %>
  <div style="margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
    <span data-gym-schedule-target="statusBadge"
          class="type-text" style="background: var(--d2); color: var(--l2); border-color: var(--d1);">
      <%= @schedule.status.upcase %>
    </span>
    <span data-gym-schedule-target="statusInfo" style="font-size: 10px; color: var(--d2);">
      Proposed by <%= @schedule.proposer_name %>
    </span>
  </div>

  <%# ── RSVP Grid ── %>
  <div class="gb-card" style="padding: 16px; margin-bottom: 12px;">
    <div style="font-size: 12px; margin-bottom: 12px;">RSVPS</div>
    <div class="gb-grid-4" data-gym-schedule-target="rsvpGrid">
      <% @players.each do |player| %>
        <div class="gb-card-dark" style="text-align: center; padding: 10px;"
             data-player-id="<%= player['discord_user_id'].to_s %>">
          <div style="font-size: 11px; color: var(--l2);"><%= player['display_name'] %></div>
          <div class="rsvp-status" style="font-size: 10px; margin-top: 6px; color: var(--l1);">Pending</div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── RSVP Buttons ── %>
  <div data-gym-schedule-target="rsvpActions"
       class="gb-card" style="text-align: center; padding: 16px; margin-bottom: 12px;">
    <div style="font-size: 11px; color: var(--d2); margin-bottom: 12px;">Are you available?</div>
    <div style="display: flex; justify-content: center; gap: 8px;">
      <button type="button"
              data-action="click->gym-schedule#rsvpYes"
              class="gb-btn-primary gb-btn-sm">
        YES
      </button>
      <button type="button"
              data-action="click->gym-schedule#rsvpMaybe"
              class="gb-btn gb-btn-sm">
        MAYBE
      </button>
      <button type="button"
              data-action="click->gym-schedule#rsvpNo"
              class="gb-btn-danger gb-btn-sm">
        NO
      </button>
    </div>
  </div>

  <%# ── Cancel Button ── %>
  <div data-gym-schedule-target="cancelAction" style="text-align: center;">
    <button type="button"
            data-action="click->gym-schedule#cancel"
            class="gb-btn-danger gb-btn-sm" style="opacity: 0.6;">
      Cancel this schedule
    </button>
  </div>
</div>
