<%# Interactive Sinnoh map: game map background image with pin marker overlays.
    Pin positions are defined in config/soul_link/map_coordinates.yml.
    Each pin is clickable via Stimulus actions. %>
<svg viewBox="<%= map_data['viewbox'] %>"
     class="w-full h-auto"
     style="max-height: 75vh;"
     preserveAspectRatio="xMidYMid meet"
     data-sinnoh-map-target="svg"
     xmlns="http://www.w3.org/2000/svg"
     xmlns:xlink="http://www.w3.org/1999/xlink">

  <%# ── SVG Definitions ── %>
  <defs>
    <%# Drop shadow for pins %>
    <filter id="pin-shadow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#000" flood-opacity="0.6"/>
    </filter>

    <%# Glow for caught pins %>
    <filter id="pin-glow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="0" dy="0" stdDeviation="3" flood-color="#3b82f6" flood-opacity="0.6"/>
    </filter>

    <%# Red glow for dead pins %>
    <filter id="pin-dead-glow" x="-50%" y="-50%" width="200%" height="200%">
      <feDropShadow dx="0" dy="0" stdDeviation="3" flood-color="#ef4444" flood-opacity="0.5"/>
    </filter>

    <%# Background darkener for label readability %>
    <filter id="label-bg" x="-0.1" y="-0.1" width="1.2" height="1.3">
      <feFlood flood-color="#000000" flood-opacity="0.7" result="bg"/>
      <feMerge>
        <feMergeNode in="bg"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <%# ── Layer 0: Background Map Image ── %>
  <image href="<%= asset_path('sinnoh_map.png') %>"
         x="0" y="0"
         width="<%= map_data['viewbox'].split(' ')[2] %>"
         height="<%= map_data['viewbox'].split(' ')[3] %>"
         preserveAspectRatio="xMidYMid slice"/>

  <%# ── Layer 1: Pin Markers ── %>
  <g class="map-pins">
    <% locations.each do |key, loc_data| %>
      <% next if loc_data['type'] == 'special' %>
      <% coords = map_data.dig('locations', key) %>
      <% next unless coords %>
      <% groups = groups_by_location[key] %>
      <% status = location_status(groups) %>
      <% loc_type = loc_data['type'] || 'route' %>
      <% gym_num = loc_data['gym_number'] %>
      <% cx = coords['x'] %>
      <% cy = coords['y'] %>

      <%# Build JSON data for popover rendering %>
      <% group_json = if groups.present?
           groups.map do |g|
             {
               nickname: g.nickname,
               status: g.status,
               caught_at: g.caught_at&.strftime('%b %d'),
               eulogy: g.eulogy,
               pokemon: g.soul_link_pokemon.map { |p|
                 {
                   species: p.species,
                   player: SoulLink::GameState.player_name(p.discord_user_id),
                   sprite: SoulLink::GameState.sprite_filename(p.species)
                 }
               }
             }
           end
         end %>

      <g class="map-pin map-pin--<%= status %>"
         style="cursor: pointer;"
         data-sinnoh-map-target="location"
         data-location-key="<%= key %>"
         data-location-name="<%= loc_data['name'] %>"
         data-status="<%= status %>"
         <% if group_json %>data-groups="<%= group_json.to_json %>"<% end %>
         data-action="click->sinnoh-map#onLocationClick">

        <%# Invisible hit area %>
        <circle cx="<%= cx %>" cy="<%= cy %>" r="14" fill="transparent" stroke="none"/>

        <% case status %>
        <% when 'caught' %>
          <%# Caught: blue pin with glow %>
          <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= pin_radius(loc_type) %>"
                  fill="#3b82f6" stroke="white" stroke-width="2"
                  filter="url(#pin-glow)" class="map-pin__body"/>
          <%# Inner pokeball-style line %>
          <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= (pin_radius(loc_type) * 0.4).round %>"
                  fill="white" opacity="0.9" style="pointer-events:none;"/>

        <% when 'dead' %>
          <%# Dead: red pin with skull %>
          <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= pin_radius(loc_type) %>"
                  fill="#ef4444" stroke="white" stroke-width="2"
                  filter="url(#pin-dead-glow)" class="map-pin__body"/>
          <text x="<%= cx %>" y="<%= cy + 3 %>"
                text-anchor="middle" font-size="<%= pin_radius(loc_type) + 1 %>"
                style="pointer-events:none;">&#x2620;</text>

        <% else %>
          <%# Uncaught: subtle gray pin %>
          <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= pin_radius(loc_type) - 1 %>"
                  fill="#6b7280" stroke="white" stroke-width="1.5"
                  opacity="0.55" filter="url(#pin-shadow)" class="map-pin__body"/>
        <% end %>

        <%# Gym badge overlay (gold circle with number) %>
        <% if gym_num %>
          <% beaten = gyms_defeated >= gym_num %>
          <circle cx="<%= cx + pin_radius(loc_type) + 4 %>" cy="<%= cy - pin_radius(loc_type) - 2 %>" r="7"
                  fill="<%= beaten ? '#eab308' : '#1f2937' %>"
                  stroke="<%= beaten ? '#facc15' : '#9ca3af' %>"
                  stroke-width="1.5"
                  filter="url(#pin-shadow)"
                  data-gym-badge="<%= gym_num %>"/>
          <text x="<%= cx + pin_radius(loc_type) + 4 %>" y="<%= cy - pin_radius(loc_type) + 2 %>"
                text-anchor="middle" font-size="8" font-weight="bold"
                fill="<%= beaten ? '#1f2937' : '#d1d5db' %>"
                style="pointer-events:none;"><%= gym_num %></text>
        <% end %>

        <%# Group nickname label (for caught/dead) %>
        <% if groups.present? %>
          <% group = primary_group(groups) %>
          <rect x="<%= cx - (group.nickname.truncate(14).length * 2.8).round %>"
                y="<%= cy - pin_radius(loc_type) - 17 %>"
                width="<%= (group.nickname.truncate(14).length * 5.6).round %>"
                height="12" rx="3"
                fill="<%= status == 'dead' ? 'rgba(127,29,29,0.85)' : 'rgba(30,58,95,0.85)' %>"
                stroke="<%= status == 'dead' ? '#fca5a5' : '#93c5fd' %>"
                stroke-width="0.5"
                style="pointer-events:none;"/>
          <text x="<%= cx %>" y="<%= cy - pin_radius(loc_type) - 8 %>"
                text-anchor="middle" font-size="7" font-weight="bold"
                fill="<%= status == 'dead' ? '#fca5a5' : '#93c5fd' %>"
                style="pointer-events:none;">
            <%= group.nickname.truncate(14) %>
          </text>
        <% end %>
      </g>
    <% end %>
  </g>
</svg>
