<div data-controller="timeline"
     data-timeline-gyms-defeated-value="<%= @gyms_defeated %>"
     data-timeline-csrf-value="<%= form_authenticity_token %>"
     data-timeline-gym-progress-url-value="<%= gym_progress_path %>"
     data-timeline-create-group-url-value="<%= pokemon_groups_path %>"
     data-timeline-pokedex-species-value="<%= @pokedex_species.to_json %>"
     data-timeline-sprite-map-value="<%= SoulLink::GameState.pokedex.to_json %>"
     style="position: relative;">

  <%# ── HEADER: Title + Gym Badges ── %>
  <div style="margin-bottom: 12px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 8px;">
    <div>
      <div class="gb-page-title">ROUTE PROGRESSION</div>
      <div class="gb-page-subtitle">Click a location to view catches or add new ones.</div>
    </div>

    <%# Gym badges %>
    <div style="display: flex; align-items: center; gap: 4px;">
      <span style="font-size: 10px; color: var(--d2); margin-right: 4px;">Badges:</span>
      <% SoulLink::GameState.gym_info.each do |key, gym| %>
        <% num = gym['number'] %>
        <% beaten = @gyms_defeated >= num %>
        <button style="width: 28px; height: 28px; border: var(--border-thin); display: flex; align-items: center; justify-content: center; font-size: 10px; cursor: pointer;
                       <%= beaten ? 'background: var(--d1); color: var(--l2);' : 'background: var(--l2); color: var(--d2);' %>"
                data-action="click->timeline#toggleGym"
                data-gym-number="<%= num %>"
                title="<%= gym['name'] %> — <%= gym['leader'] %> (<%= gym['type'] %>) — Lv. <%= gym['max_level'] %>">
          <%= num %>
        </button>
      <% end %>
    </div>
  </div>

  <%# ── LEVEL CAP INFO ── %>
  <% next_gym = SoulLink::GameState.next_gym_info(@gyms_defeated) %>
  <% if next_gym %>
    <div class="gb-card-dark" style="display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; margin-bottom: 12px; font-size: 10px;">
      <span style="color: var(--l1);">Next Gym:</span>
      <span style="color: var(--l2);"><%= next_gym['name'] %></span>
      <span style="color: var(--l1);">(<%= next_gym['leader'] %> &mdash; <%= next_gym['type'] %>)</span>
      <span style="color: var(--l2); margin-left: 6px;">Level Cap: <%= next_gym['max_level'] %></span>
    </div>
  <% else %>
    <div class="gb-card-dark" style="display: inline-flex; padding: 6px 12px; margin-bottom: 12px; font-size: 10px;">
      <span style="color: var(--l2);">All 8 badges earned! Prepare for the Elite Four.</span>
    </div>
  <% end %>

  <%# ── HORIZONTAL TIMELINE ── %>
  <div class="gb-card" style="overflow: hidden; padding: 0;">
    <div style="overflow-x: auto; overflow-y: hidden; padding-bottom: 8px; scrollbar-width: thin; scrollbar-color: var(--d2) var(--l1);"
         class="timeline-scroll"
         data-timeline-target="scrollContainer">
      <div style="display: flex; align-items: flex-start; gap: 0; padding: 24px 16px 12px; min-width: max-content;"
           data-timeline-target="track">

        <% segments = @progression['segments'] || [] %>
        <% segments.each_with_index do |segment, seg_idx| %>
          <% (segment['locations'] || []).each_with_index do |loc_key, loc_idx| %>
            <% loc_data = @locations[loc_key] %>
            <% next unless loc_data %>
            <% groups = @groups_by_location[loc_key] %>
            <% status = location_status(groups) %>
            <% loc_type = loc_data['type'] || 'route' %>
            <% group = primary_group(groups) %>

            <%# Connecting line %>
            <% unless seg_idx == 0 && loc_idx == 0 %>
              <div style="width: 24px; height: 2px; flex-shrink: 0; margin-top: 16px;
                          background: <%= status != 'uncaught' ? 'var(--d2)' : 'var(--l1)' %>;"></div>
            <% end %>

            <%# Location Node %>
            <button style="flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 2px; cursor: pointer; min-width: 56px; background: none; border: none; font-family: 'Press Start 2P', monospace; position: relative;"
                    data-action="click->timeline#selectLocation"
                    data-timeline-target="locationNode"
                    data-location-key="<%= loc_key %>"
                    data-location-name="<%= loc_data['name'] %>"
                    data-status="<%= status %>"
                    data-groups="<%= groups_json_for(groups) %>">

              <%# Node circle %>
              <div class="timeline-node" style="<%= timeline_node_size(loc_type) == 'w-8 h-8' ? 'width: 32px; height: 32px;' : 'width: 28px; height: 28px;' %>
                          border: var(--border-thin); display: flex; align-items: center; justify-content: center;
                          <% if status == 'caught' %>
                            background: var(--d2); border-color: var(--d1);
                          <% elsif status == 'dead' %>
                            background: #4a1c1c; border-color: #6b2c2c;
                          <% else %>
                            background: var(--l2); border-color: var(--d2); opacity: 0.6;
                          <% end %>">
                <% if status == 'dead' %>
                  <span style="font-size: 10px;">&#9760;</span>
                <% elsif status == 'caught' && group %>
                  <% first_pokemon = group.soul_link_pokemon.first %>
                  <% if first_pokemon %>
                    <%= pokemon_sprite_tag(first_pokemon.species, size: 20) %>
                  <% else %>
                    <span style="color: var(--l2); font-size: 10px;">&#10003;</span>
                  <% end %>
                <% elsif loc_type == 'special' %>
                  <span style="color: var(--d2); font-size: 10px;">&#9733;</span>
                <% end %>
              </div>

              <%# Location label %>
              <span style="font-size: 9px; color: var(--d2); white-space: nowrap; max-width: 56px; overflow: hidden; text-overflow: ellipsis; text-align: center; line-height: 1.3;">
                <%= loc_data['name'] %>
              </span>

              <%# Nickname label %>
              <% if group %>
                <span style="font-size: 9px; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 56px;
                             <%= status == 'dead' ? 'color: #e8a0a0;' : 'color: var(--d1);' %>">
                  <%= group.nickname&.truncate(10) %>
                </span>
              <% else %>
                <span style="font-size: 9px; color: transparent; line-height: 1.3;">&nbsp;</span>
              <% end %>
            </button>
          <% end %>

          <%# ── GYM MILESTONE ── %>
          <% if segment['gym'] %>
            <% gym = @gym_info[segment['gym']] %>
            <% if gym %>
              <% beaten = @gyms_defeated >= gym['number'] %>

              <div style="width: 16px; height: 2px; flex-shrink: 0; margin-top: 16px;
                          background: <%= beaten ? 'var(--d1)' : 'var(--l1)' %>;"></div>

              <div style="flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 2px; min-width: 56px;">
                <button style="width: 36px; height: 36px; border: var(--border-thin); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; cursor: pointer; font-family: 'Press Start 2P', monospace;
                               <%= beaten ? 'background: var(--d1); color: var(--l2); border-color: var(--d1);' : 'background: var(--l2); color: var(--d2); border-color: var(--d2);' %>"
                        data-action="click->timeline#toggleGym"
                        data-gym-number="<%= gym['number'] %>"
                        title="<%= gym['name'] %> — <%= gym['leader'] %> (<%= gym['type'] %>)">
                  <%= gym['number'] %>
                </button>
                <span style="font-size: 9px; white-space: nowrap; line-height: 1.3;
                             <%= beaten ? 'color: var(--d1);' : 'color: var(--d2);' %>">
                  <%= gym['leader'] %>
                </span>
                <span style="font-size: 9px; color: var(--d2); white-space: nowrap; line-height: 1.3;">
                  Lv. <%= gym['max_level'] %>
                </span>
              </div>

              <div style="width: 16px; height: 2px; flex-shrink: 0; margin-top: 16px;
                          background: <%= beaten ? 'var(--d1)' : 'var(--l1)' %>;"></div>
            <% end %>
          <% end %>
        <% end %>

        <%# ── ENDPOINT: Elite Four ── %>
        <div style="width: 24px; height: 2px; flex-shrink: 0; margin-top: 16px; background: var(--l1);"></div>
        <div style="flex-shrink: 0; display: flex; flex-direction: column; align-items: center; gap: 2px; min-width: 56px;">
          <div style="width: 40px; height: 40px; border: var(--border-thin); border-color: var(--d1); background: var(--d2); display: flex; align-items: center; justify-content: center; font-size: 16px;">
            &#128081;
          </div>
          <span style="font-size: 9px; color: var(--d1); white-space: nowrap; line-height: 1.3;">Elite Four</span>
          <span style="font-size: 9px; color: transparent; line-height: 1.3;">&nbsp;</span>
        </div>
      </div>
    </div>
  </div>

  <%# ── SPECIAL ENCOUNTERS ── %>
  <div style="margin-top: 16px;">
    <div class="gb-section-header">SPECIAL ENCOUNTERS</div>
    <div class="gb-grid-4">
      <% %w[gift egg trade other].each do |key| %>
        <% groups = @groups_by_location[key] %>
        <% status = location_status(groups) %>
        <% loc = @locations[key] %>
        <button class="<%= status == 'dead' ? 'gb-status-dead' : '' %>"
                style="border: var(--border-thin); padding: 8px; text-align: left; cursor: pointer; font-family: 'Press Start 2P', monospace;
                       <%= if status == 'caught' then 'background: var(--d2); color: var(--l2);'
                           elsif status == 'dead' then 'background: #4a1c1c; border-color: #6b2c2c;'
                           else 'background: var(--l1);'
                           end %>"
                data-action="click->timeline#selectLocation"
                data-timeline-target="locationNode"
                data-location-key="<%= key %>"
                data-location-name="<%= loc&.dig('name') || key.titleize %>"
                data-status="<%= status %>"
                data-groups="<%= groups_json_for(groups) %>">
          <div style="font-size: 11px; <%= status == 'caught' ? 'color: var(--l2);' : status == 'dead' ? 'color: #e8a0a0;' : '' %>">
            <%= loc&.dig('name') || key.titleize %>
          </div>
          <% if groups.present? %>
            <% group = primary_group(groups) %>
            <div style="font-size: 9px; margin-top: 4px; <%= status == 'dead' ? 'color: #e8a0a0;' : 'color: var(--l1);' %>">
              <%= group.dead? ? "\u{1F480} " : '' %><%= group.nickname %>
            </div>
            <div style="display: flex; flex-wrap: wrap; gap: 2px; margin-top: 4px;">
              <% group.soul_link_pokemon.each do |pokemon| %>
                <%= pokemon_sprite_tag(pokemon.species, size: 16) %>
              <% end %>
            </div>
          <% else %>
            <div style="font-size: 9px; color: var(--d2); margin-top: 4px;">No catch yet</div>
          <% end %>
        </button>
      <% end %>
    </div>
  </div>

  <%# ── SLIDE-OUT PANEL ── %>
  <div data-timeline-target="panel"
       style="position: fixed; inset: 0 0 0 auto; z-index: 40; width: 100%; max-width: 380px;
              transform: translateX(100%); transition: transform 0.3s ease-in-out;
              background: var(--l1); border-left: var(--border); overflow-y: auto;">

    <%# Panel header %>
    <div style="position: sticky; top: 0; background: var(--d1); padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; z-index: 10;">
      <span style="font-size: 14px; color: var(--l2);" data-timeline-target="panelTitle"></span>
      <button data-action="click->timeline#closePanel"
              style="font-size: 18px; color: var(--l1); background: none; border: none; cursor: pointer; font-family: 'Press Start 2P', monospace;">&times;</button>
    </div>

    <%# Panel body (populated by JS) %>
    <div data-timeline-target="panelBody" style="padding: 12px 16px;"></div>

    <%# Catch form %>
    <div data-timeline-target="panelForm" class="hidden" style="padding: 12px 16px; border-top: var(--border-thin);">
      <div style="font-size: 12px; margin-bottom: 8px;">NEW CATCH</div>
      <form data-action="submit->timeline#submitCatch">
        <input type="hidden" name="location" data-timeline-target="formLocationKey">

        <div style="margin-bottom: 10px;">
          <label class="gb-label">GROUP NICKNAME</label>
          <input type="text" name="nickname" required autocomplete="off"
                 data-timeline-target="nicknameInput"
                 class="gb-input"
                 placeholder="e.g. Chandler, RACHEL...">
        </div>

        <% @players.each do |player| %>
          <div style="margin-bottom: 10px; position: relative;" data-timeline-target="speciesSearchWrapper">
            <label class="gb-label"><%= player['display_name'].upcase %>'S SPECIES</label>
            <div style="display: flex; align-items: center; gap: 6px;">
              <span data-timeline-target="speciesPreview" style="width: 28px; height: 28px; flex-shrink: 0;"></span>
              <input type="text"
                     placeholder="Search species..."
                     autocomplete="off"
                     data-action="input->timeline#filterSpecies focus->timeline#filterSpecies"
                     data-player-id="<%= player['discord_user_id'] %>"
                     class="gb-input" style="flex: 1;">
            </div>
            <input type="hidden"
                   name="species[<%= player['discord_user_id'] %>]"
                   data-timeline-target="speciesHidden">
            <div class="hidden" data-timeline-target="speciesDropdown"
                 style="position: absolute; z-index: 10; left: 34px; right: 0; margin-top: 2px; max-height: 180px; overflow-y: auto;
                        background: var(--l2); border: var(--border-thin);"></div>
          </div>
        <% end %>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 12px;">
          <span data-timeline-target="formStatus" style="font-size: 10px; color: var(--d2);"></span>
          <button type="submit" class="gb-btn-primary gb-btn-sm">ADD CATCH</button>
        </div>
      </form>
    </div>
  </div>

  <%# Backdrop overlay %>
  <div data-timeline-target="backdrop"
       data-action="click->timeline#closePanel"
       class="hidden" style="position: fixed; inset: 0; z-index: 30; background: rgba(15, 56, 15, 0.5);"></div>
</div>
