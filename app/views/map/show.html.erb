<%# Step 23 R4 — standalone /map redesign per
    handoff/2026-05-04-ui-audit-mockup-map.html. All visual styles
    namespaced under `.map-r4`. The dashboard + pixeldex controllers
    are attached so the rendered `_pokemon_modal.html.erb` and
    `_mark_dead_modal.html.erb` partials at the bottom of this view
    work without bespoke wiring. Existing timeline actions are
    preserved verbatim; new sheet / hash / jumpToNow logic layers
    on top in `timeline_controller.js`. %>
<%
  next_uncaught_key = next_uncaught_route_key(@progression, @locations, @groups_by_location)
  next_gym = SoulLink::GameState.next_gym_info(@gyms_defeated)
  current_seg_label = current_segment_label(@progression, @gym_info, next_uncaught_key)
%>
<div class="map-r4"
     data-controller="timeline dashboard pixeldex ability-tooltip"
     data-timeline-gyms-defeated-value="<%= @gyms_defeated %>"
     data-timeline-csrf-value="<%= form_authenticity_token %>"
     data-timeline-gym-progress-url-value="<%= gym_progress_path %>"
     data-timeline-create-group-url-value="<%= pokemon_groups_path %>"
     data-timeline-pokedex-species-value="<%= @pokedex_species.to_json %>"
     data-timeline-sprite-map-value="<%= SoulLink::GameState.pokedex.to_json %>"
     data-dashboard-groups-url-value="<%= pokemon_groups_path %>"
     data-dashboard-csrf-value="<%= form_authenticity_token %>"
     data-dashboard-user-id-value="<%= current_user_id %>"
     data-pixeldex-abilities-data-value="<%= SoulLink::GameState.pokemon_abilities.to_json %>"
     data-pixeldex-evolutions-data-value="<%= SoulLink::GameState.evolutions.to_json %>"
     data-pixeldex-sprite-map-value="<%= pixeldex_sprite_urls.to_json %>"
     data-pixeldex-natures-data-value="<%= PixeldexHelper::NATURES.to_json %>"
     data-pixeldex-ability-effects-data-value="<%= SoulLink::GameState.ability_effects.to_json %>"
     data-pixeldex-pokemon-update-url-value="/pokemon"
     data-pixeldex-group-update-url-value="<%= pokemon_groups_path %>"
     data-pixeldex-update-slots-url-value="<%= update_slots_team_path %>"
     data-pixeldex-csrf-value="<%= form_authenticity_token %>">

  <%# ── Map header — Step 27: rebased to gb-page-title + subtitle.
      Boxed background dropped; the title and subtitle alone carry the
      surface. Legend is inlined into the subtitle line per audit § 3.4
      (no separate boxed legend bar). ── %>
  <div class="map-head">
    <h2>ROUTE PROGRESSION</h2>
    <div class="sub">Click any node to view catches or add a new one. Legend: &#9679; caught &middot; &#9760; dead &middot; &#9675; uncaught &middot; &#9733; special &middot; G gym</div>
  </div>

  <%# Step 27: badge-strip hoisted into its own gb-section with a
      gb-section-header — replaces the inline LBL "BADGES" prefix. %>
  <section class="badge-strip-section">
    <h3 class="gb-section-header">BADGES</h3>
    <div class="badge-strip">
      <% SoulLink::GameState.gym_info.each do |_key, gym| %>
        <% num = gym["number"] %>
        <% beaten = @gyms_defeated >= num %>
        <button type="button"
                class="badge<%= beaten ? ' earned' : '' %>"
                data-action="click->timeline#toggleGym"
                data-gym-number="<%= num %>"
                title="<%= gym['name'] %> &mdash; <%= gym['leader'] %> &mdash; Lv. <%= gym['max_level'] %>">
          <%= num %>
        </button>
      <% end %>
    </div>
  </section>

  <%# ── Status bar ── %>
  <div class="status-bar">
    <% if next_gym %>
      <div class="item">
        <span class="lbl">NEXT GYM</span>
        <span class="val"><%= next_gym["leader"] %></span>
      </div>
      <div class="item">
        <span class="lbl">LEVEL CAP</span>
        <span class="val"><%= next_gym["max_level"] %></span>
      </div>
    <% else %>
      <div class="item">
        <span class="lbl">NEXT GYM</span>
        <span class="val">All 8 earned &middot; Elite Four ahead</span>
      </div>
      <div class="item">
        <span class="lbl">LEVEL CAP</span>
        <span class="val">&mdash;</span>
      </div>
    <% end %>
    <div class="item">
      <span class="lbl">CURRENT SEG</span>
      <span class="val"><%= current_seg_label %></span>
    </div>
    <button type="button"
            class="jump-btn<%= next_uncaught_key.nil? ? ' hidden' : '' %>"
            data-timeline-target="jumpBtn"
            data-action="click->timeline#jumpToNow">&#x2193; JUMP TO NOW</button>
  </div>

  <%# ── Layout: timeline + sticky sheet ── %>
  <div class="layout">
    <div>
      <%# ── Desktop: horizontal timeline ── %>
      <div class="timeline-frame">
        <div class="timeline-scroll" data-timeline-target="scrollContainer">
          <div class="timeline-track" data-timeline-target="track">

            <% segments = @progression["segments"] || [] %>
            <% segments.each_with_index do |segment, seg_idx| %>
              <% (segment["locations"] || []).each_with_index do |loc_key, loc_idx| %>
                <% loc_data = @locations[loc_key] %>
                <% next unless loc_data %>
                <% groups = @groups_by_location[loc_key] %>
                <% status = location_status(groups) %>
                <% loc_type = loc_data["type"] || "route" %>
                <% group = primary_group(groups) %>
                <% node_class = node_status_class(loc_data, status) %>
                <% is_next = (loc_key == next_uncaught_key) %>

                <%# Connecting line — between every node within a segment %>
                <% unless seg_idx == 0 && loc_idx == 0 %>
                  <div class="timeline-line <%= status == 'uncaught' ? 'todo' : 'done' %>"></div>
                <% end %>

                <%# Location node %>
                <button type="button"
                        class="node <%= node_class %><%= is_next ? ' next' : '' %>"
                        data-action="click->timeline#selectLocation"
                        data-timeline-target="locationNode"
                        data-location-key="<%= loc_key %>"
                        data-location-name="<%= loc_data['name'] %>"
                        data-status="<%= status %>"
                        data-groups="<%= groups_json_for(groups, current_user_id) %>">
                  <% if is_next %>
                    <span class="node-now-pin">&#x2193; NOW</span>
                  <% end %>
                  <div class="glyph">
                    <% if status == "dead" %>
                      <span style="font-size: 12px;">&#9760;</span>
                    <% elsif status == "caught" && group %>
                      <% first_pokemon = group.soul_link_pokemon.first %>
                      <% if first_pokemon %>
                        <%= pokemon_sprite_tag(first_pokemon.species, size: 36) %>
                      <% else %>
                        <span style="font-size: 12px;">&#9679;</span>
                      <% end %>
                    <% elsif loc_type == "special" %>
                      <span style="font-size: 11px;">&#9733;</span>
                    <% else %>
                      <span style="font-size: 12px;">&#9675;</span>
                    <% end %>
                  </div>
                  <div class="label"><%= loc_data["name"] %></div>
                  <% if group %>
                    <div class="nick"><%= group.nickname.to_s.truncate(10) %></div>
                  <% end %>
                </button>
              <% end %>

              <%# Gym milestone (per-segment, before the divider) %>
              <% if segment["gym"] %>
                <% gym = @gym_info[segment["gym"]] %>
                <% if gym %>
                  <% beaten = @gyms_defeated >= gym["number"] %>
                  <div class="timeline-line <%= beaten ? 'done' : 'todo' %>"></div>
                  <button type="button"
                          class="node gym<%= beaten ? ' beaten' : '' %>"
                          data-action="click->timeline#toggleGym"
                          data-gym-number="<%= gym['number'] %>"
                          title="<%= gym['name'] %> &mdash; <%= gym['leader'] %>">
                    <div class="glyph"><%= gym["number"] %></div>
                    <div class="label"><%= gym["leader"].to_s.upcase %><br>Lv <%= gym["max_level"] %></div>
                  </button>
                <% end %>
              <% end %>

              <%# Segment divider (between segments — not after the last) %>
              <% divider_label = segment_divider_label(@progression, @gym_info, seg_idx) %>
              <% if divider_label %>
                <div class="timeline-segment-divider" data-segment="<%= divider_label %>"></div>
              <% end %>
            <% end %>

            <%# Endpoint: Elite Four %>
            <div class="timeline-line todo"></div>
            <div class="node">
              <div class="glyph" style="width: 56px; height: 56px; background: var(--d2); border-color: var(--d1); color: var(--white); font-family: 'Press Start 2P', monospace; font-size: 12px;">EF</div>
              <div class="label">ELITE FOUR</div>
            </div>
          </div>
        </div>
      </div>

      <%# ── Mobile: per-segment accordion ── %>
      <div class="accordion-frame">
        <% (@progression["segments"] || []).each_with_index do |segment, seg_idx| %>
          <% prog = segment_progress(segment, @locations, @groups_by_location) %>
          <% summary_marker = if prog[:total].zero?
                                ""
                              elsif prog[:caught] >= prog[:total]
                                "&#10003;".html_safe
                              elsif segment_open_by_default?(segment, next_uncaught_key)
                                "NOW"
                              else
                                ""
                              end %>
          <% gym_for_label = @gym_info[segment["gym"]] %>
          <% seg_label = if gym_for_label
                          gym_for_label["location"].to_s.sub(/_city\z/, "").sub(/_town\z/, "").upcase
                        elsif segment["gym"].nil?
                          "VICTORY ROAD"
                        else
                          "SEG #{seg_idx + 1}"
                        end %>
          <details class="accordion-segment"<%= ' open'.html_safe if segment_open_by_default?(segment, next_uncaught_key) %>
                   data-timeline-target="accordionSegment">
            <summary>
              SEG <%= seg_idx + 1 %> &middot; <%= seg_label %>
              <span class="seg-progress"><%= prog[:caught] %>/<%= prog[:total] %> <%= summary_marker %></span>
            </summary>
            <div class="acc-rows">
              <% (segment["locations"] || []).each do |loc_key| %>
                <% loc_data = @locations[loc_key] %>
                <% next unless loc_data %>
                <% groups = @groups_by_location[loc_key] %>
                <% status = location_status(groups) %>
                <% group = primary_group(groups) %>
                <% node_class = node_status_class(loc_data, status) %>
                <% is_next = (loc_key == next_uncaught_key) %>
                <button type="button"
                        class="acc-row"
                        data-action="click->timeline#selectLocation"
                        data-timeline-target="locationNode"
                        data-location-key="<%= loc_key %>"
                        data-location-name="<%= loc_data['name'] %>"
                        data-status="<%= status %>"
                        data-groups="<%= groups_json_for(groups, current_user_id) %>">
                  <div class="glyph <%= node_class %><%= is_next ? ' next' : '' %>">
                    <% if status == "dead" %>
                      &#9760;
                    <% elsif status == "caught" %>
                      &#9679;
                    <% elsif loc_data["type"] == "special" %>
                      &#9733;
                    <% else %>
                      &#9675;
                    <% end %>
                  </div>
                  <div class="meta">
                    <div class="loc"><%= loc_data["name"].to_s.upcase %></div>
                    <% if group %>
                      <div class="nick<%= group.dead? ? ' dead' : '' %>"><%= group.nickname %></div>
                    <% elsif is_next %>
                      <div class="nick" style="color: var(--accent);">&#x2193; NOW &middot; log first encounter</div>
                    <% else %>
                      <div class="nick">&mdash; uncaught &mdash;</div>
                    <% end %>
                  </div>
                  <span class="chev">&#x203A;</span>
                </button>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>

      <%# ── Special encounters bar ── %>
      <div class="special-bar">
        <h3>SPECIAL ENCOUNTERS</h3>
        <div class="special-grid">
          <% %w[gift egg trade other].each do |key| %>
            <% groups = @groups_by_location[key] %>
            <% status = location_status(groups) %>
            <% loc = @locations[key] %>
            <% group = primary_group(groups) %>
            <% display_name = loc&.dig("name") || key.titleize %>
            <button type="button"
                    class="special-cell"
                    data-action="click->timeline#selectLocation"
                    data-timeline-target="locationNode"
                    data-location-key="<%= key %>"
                    data-location-name="<%= display_name %>"
                    data-status="<%= status %>"
                    data-groups="<%= groups_json_for(groups, current_user_id) %>">
              <div class="head">
                <span class="name"><%= key.upcase %></span>
                <span class="glyph-mini">&#9733;</span>
              </div>
              <div class="body">
                <% if group %>
                  <%= group.dead? ? "\u{1F480} ".html_safe : "" %><%= group.nickname %>
                <% else %>
                  No catch yet
                <% end %>
              </div>
            </button>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Right rail: sticky sheet ── %>
    <aside class="sheet" data-timeline-target="sheet">
      <div class="sheet-head">
        <h3 data-timeline-target="sheetTitle">Select a route</h3>
        <button type="button"
                class="close"
                aria-label="Close sheet"
                data-action="click->timeline#closePanel">CLOSE &#10005;</button>
      </div>
      <div class="sheet-body" data-timeline-target="sheetBody">

        <%# Empty / idle state — visible until a route is selected. %>
        <div class="empty-state" data-timeline-target="emptyState">
          Select a route to view or log catches.
        </div>

        <%# Group list — populated by JS (`_renderSheetGroupList`). %>
        <div class="hidden" data-timeline-target="groupList"></div>

        <%# Catch form — hidden in read-only (wiped) mode. %>
        <% unless dashboard_read_only?(@run) %>
          <form class="hidden"
                data-timeline-target="sheetForm"
                data-action="submit->timeline#submitCatch">
            <input type="hidden" name="location" data-timeline-target="formLocationKey">

            <div class="form-row">
              <label>GROUP NICKNAME</label>
              <input type="text"
                     name="nickname"
                     required
                     autocomplete="off"
                     data-timeline-target="nicknameInput"
                     placeholder="e.g. Chandler, RACHEL...">
            </div>

            <% @players.each do |player| %>
              <div class="form-row" data-timeline-target="speciesSearchWrapper">
                <label><%= player["display_name"].upcase %>&apos;S SPECIES</label>
                <div class="player-row">
                  <span class="pname"><%= player["display_name"].upcase %></span>
                  <div class="pinput">
                    <span class="preview" data-timeline-target="speciesPreview">SPR</span>
                    <input type="text"
                           placeholder="Search species&hellip;"
                           autocomplete="off"
                           data-action="input->timeline#filterSpecies focus->timeline#filterSpecies"
                           data-player-id="<%= player['discord_user_id'] %>">
                    <input type="hidden"
                           name="species[<%= player['discord_user_id'] %>]"
                           data-timeline-target="speciesHidden">
                    <div class="species-dropdown hidden" data-timeline-target="speciesDropdown"></div>
                  </div>
                </div>
              </div>
            <% end %>

            <button type="submit" class="submit-btn">+ LOG GROUP</button>
            <span class="form-status" data-timeline-target="formStatus"></span>
          </form>
        <% end %>
      </div>
    </aside>
  </div>

  <%# Render the dashboard's pokemon + mark-dead modals — Step 23 R4
      reuses these partials so the in-sheet EDIT and MARK DEAD actions
      dispatch into the same Stimulus targets the dashboard uses.
      Both partials are ARIA-wired (Step 20). %>
  <%= render "dashboard/pokemon_modal" %>
  <%= render "dashboard/mark_dead_modal" %>
</div>
