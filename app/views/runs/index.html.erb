<div data-controller="run-management"
     data-run-management-guild-id-value="<%= @guild_id %>"
     data-run-management-user-id-value="<%= current_user_id %>">

  <div style="margin-bottom: 16px;">
    <div class="gb-page-title">RUN MANAGEMENT</div>
    <div class="gb-page-subtitle">Start new runs, view history, and manage Discord channels.</div>
  </div>

  <%# ── Current Run Panel ── %>
  <div data-run-management-target="currentRunPanel" class="<%= 'hidden' unless @current_run %>">
    <div class="gb-card" style="padding: 16px;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
        <div style="font-size: 14px;">
          CURRENT RUN: <span data-run-management-target="runNumber">#<%= @current_run&.run_number %></span>
        </div>
        <span class="type-text" style="border-color: var(--d1); background: var(--d2); color: var(--l2);">ACTIVE</span>
      </div>

      <div class="gb-grid-4" style="margin-bottom: 16px;">
        <div class="gb-card-dark" style="text-align: center; padding: 10px;">
          <div style="font-size: 18px; color: var(--l2);" data-run-management-target="gymsDefeated"><%= @current_run&.gyms_defeated || 0 %>/8</div>
          <div style="font-size: 9px; color: var(--l1); margin-top: 4px;">GYMS</div>
        </div>
        <div class="gb-card-dark" style="text-align: center; padding: 10px;">
          <div style="font-size: 18px; color: var(--l2);" data-run-management-target="caughtCount"><%= @current_run&.caught_groups&.count || 0 %></div>
          <div style="font-size: 9px; color: var(--l1); margin-top: 4px;">CAUGHT</div>
        </div>
        <div class="gb-card-dark" style="text-align: center; padding: 10px;">
          <div style="font-size: 18px; color: var(--l2);" data-run-management-target="deadCount"><%= @current_run&.dead_groups&.count || 0 %></div>
          <div style="font-size: 9px; color: var(--l1); margin-top: 4px;">DEAD</div>
        </div>
        <div class="gb-card-dark" style="text-align: center; padding: 10px;">
          <div style="font-size: 11px; color: var(--l2);" data-run-management-target="startedAt"><%= @current_run&.created_at&.strftime("%b %-d, %Y") %></div>
          <div style="font-size: 9px; color: var(--l1); margin-top: 4px;">STARTED</div>
        </div>
      </div>

      <div data-run-management-target="errorMessage"
           class="hidden gb-flash gb-flash-alert" style="margin-bottom: 12px;">
      </div>

      <div style="display: flex; align-items: center; gap: 8px;">
        <button data-action="click->run-management#endRun"
                class="gb-btn-danger gb-btn-sm">
          End Current Run
        </button>
        <button data-action="click->run-management#setupDiscord"
                data-run-management-target="setupDiscordButton"
                class="gb-btn-primary gb-btn-sm <%= 'hidden' if @current_run&.discord_channels_configured? %>">
          Setup Discord
        </button>
        <button data-action="click->run-management#generateEmulatorRoms"
                data-run-management-target="generateRomsButton"
                class="gb-btn-primary gb-btn-sm <%= 'hidden' if @current_run&.emulator_status != :none %>">
          Generate Emulator ROMs
        </button>
        <button data-action="click->run-management#regenerateEmulatorRoms"
                data-run-management-target="regenerateRomsButton"
                class="gb-btn-primary gb-btn-sm <%= 'hidden' if @current_run&.emulator_status != :failed %>">
          Regenerate ROMs
        </button>
      </div>
    </div>
  </div>

  <%# ── No Active Run Panel ── %>
  <div data-run-management-target="noRunPanel" class="<%= 'hidden' if @current_run %>">
    <div class="gb-card" style="text-align: center; padding: 20px;">
      <div style="font-size: 11px; color: var(--d2); margin-bottom: 12px;">No active run. Start a new one to begin tracking.</div>
      <div data-run-management-target="errorMessage"
           class="hidden gb-flash gb-flash-alert" style="margin-bottom: 12px;">
      </div>
      <button data-action="click->run-management#startRun"
              class="gb-btn-primary">
        START NEW RUN
      </button>
    </div>
  </div>

  <%# ── Run History ── %>
  <div style="margin-top: 16px;">
    <div class="gb-section-header">RUN HISTORY</div>
    <div data-run-management-target="historyList">
      <% if @past_runs.any? %>
        <% @past_runs.each do |run| %>
          <div class="gb-card" style="opacity: 0.6; padding: 10px;">
            <div style="display: flex; align-items: center; justify-content: space-between; font-size: 11px;">
              <div>
                <span>RUN #<%= run.run_number %></span>
                <span style="color: var(--d2); margin-left: 8px;">
                  <%= run.created_at.strftime("%b %-d") %> &mdash; <%= run.updated_at.strftime("%b %-d, %Y") %>
                </span>
              </div>
              <div style="display: flex; gap: 12px; font-size: 10px;">
                <span style="color: var(--d2);"><%= run.gyms_defeated %>/8 gyms</span>
                <span style="color: var(--d2);"><%= run.caught_groups.count %> caught</span>
                <span style="color: var(--d2);"><%= run.dead_groups.count %> dead</span>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="gb-card" style="font-size: 11px; color: var(--d2); text-align: center; padding: 16px;">
          No previous runs.
        </div>
      <% end %>
    </div>
  </div>
</div>
