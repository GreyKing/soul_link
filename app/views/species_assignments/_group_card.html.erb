<div class="<%= group.dead? ? 'bg-gray-800/50 border-red-900/50' : 'bg-gray-800 border-gray-700' %> rounded-lg border p-4" data-group-id="<%= group.id %>">
  <div class="flex items-center justify-between mb-3">
    <div>
      <span class="font-semibold <%= group.dead? ? 'text-red-300' : 'text-white' %>">
        <%= group.dead? ? '💀 ' : '' %><%= group.nickname %>
      </span>
      <span class="text-xs text-gray-500 ml-2"><%= group.location %></span>
    </div>
    <% if group.dead? %>
      <span class="text-xs text-red-400">Dead</span>
    <% elsif group.complete? %>
      <span class="text-xs text-green-400">Complete</span>
    <% else %>
      <span class="text-xs text-yellow-400"><%= group.missing_players.size %> missing</span>
    <% end %>
  </div>

  <div class="space-y-2">
    <% players.each do |player| %>
      <% player_id = player['discord_user_id'] %>
      <% species_entry = group.species_for(player_id) %>
      <% is_me = player_id == current_user_id %>

      <div class="flex items-center gap-2">
        <span class="text-xs font-medium w-24 truncate <%= is_me ? 'text-indigo-300' : 'text-gray-400' %>">
          <%= player['display_name'] %>
        </span>

        <% if species_entry %>
          <%# Assigned — show locked species badge %>
          <span class="inline-flex items-center gap-1 text-xs px-3 py-1.5 rounded-lg
                       <%= is_me ? 'bg-indigo-900/60 text-indigo-200 border border-indigo-700' : 'bg-gray-700/50 text-gray-300 border border-gray-600' %>">
            <%= pokemon_sprite_tag(species_entry.species, size: 20) %>
            <%= species_entry.species %>
            <%= pokemon_type_badges(species_entry.species, size: :xs) %>
          </span>
        <% elsif is_me %>
          <%# My empty slot — drop target %>
          <div data-species-assignment-target="dropZone"
               data-group-id="<%= group.id %>"
               class="drop-zone flex-1 min-h-[36px] px-3 py-1.5 rounded-lg border-2 border-dashed border-indigo-500/50 bg-indigo-950/20 text-xs text-indigo-400 flex items-center justify-center transition hover:border-indigo-400 hover:bg-indigo-950/40">
            Drop your species here
          </div>
        <% else %>
          <%# Other player's empty slot — not interactive %>
          <span class="text-xs text-gray-600 italic px-3 py-1.5">waiting...</span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
