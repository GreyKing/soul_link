<div class="<%= group.dead? ? 'gb-card gb-status-dead' : 'gb-card' %>" style="padding: 10px;"
     data-group-id="<%= group.id %>"
     data-group-nickname="<%= group.nickname %>"
     data-group-location="<%= group.location %>"
     data-group-status="<%= group.status %>"
     data-group-eulogy="<%= group.eulogy %>">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
    <div>
      <span style="font-size: 12px; <%= group.dead? ? 'color: #e8a0a0;' : '' %>">
        <%= group.dead? ? "\u{1F480} " : '' %><%= group.nickname %>
      </span>
      <span style="font-size: 11px; font-weight: bold; color: var(--d2); margin-left: 6px;"><%= group.location %></span>
    </div>
    <div style="display: flex; align-items: center; gap: 6px; font-size: 10px;">
      <% if group.dead? %>
        <span style="color: #e8a0a0;">Dead</span>
      <% elsif group.complete? %>
        <span style="color: var(--d2);">Complete</span>
      <% else %>
        <span style="color: var(--d2);"><%= group.missing_players.size %> missing</span>
      <% end %>

      <button type="button"
              data-action="click->species-assignment#openEditGroupModal"
              class="gb-btn gb-btn-sm" style="padding: 2px 4px; font-size: 9px;">
        EDIT
      </button>
      <button type="button"
              data-action="click->species-assignment#deleteGroup"
              class="gb-btn-danger gb-btn-sm" style="padding: 2px 4px; font-size: 9px;">
        DEL
      </button>
    </div>
  </div>

  <% players.each do |player| %>
    <% player_id = player['discord_user_id'] %>
    <% species_entry = group.species_for(player_id) %>
    <% is_me = player_id == current_user_id %>

    <div style="display: flex; align-items: center; gap: 6px; margin-bottom: 4px;">
      <span style="font-size: 10px; width: 80px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
                   <%= is_me ? 'color: var(--d1); font-weight: bold;' : 'color: var(--d2);' %>">
        <%= player['display_name'] %>
      </span>

      <% if species_entry %>
        <span style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; padding: 2px 8px;
                     border: var(--border-thin); <%= is_me ? 'background: var(--d2); color: var(--l2);' : 'background: var(--l2); color: var(--d2);' %>">
          <%= pokemon_sprite_tag(species_entry.species, size: 20) %>
          <%= species_entry.species %>
          <%= pixeldex_type_badges(species_entry.species) %>
          <% if is_me %>
            <button type="button"
                    data-action="click->species-assignment#unassignSpecies"
                    data-pokemon-id="<%= species_entry.id %>"
                    style="margin-left: 4px; color: var(--l1); cursor: pointer; border: none; background: none; font-family: 'Press Start 2P', monospace; font-size: 10px;"
                    title="Remove">&times;</button>
          <% end %>
        </span>
      <% elsif is_me %>
        <div data-species-assignment-target="dropZone"
             data-group-id="<%= group.id %>"
             class="drop-zone gb-drag-zone" style="flex: 1; min-height: 32px; display: flex; align-items: center; justify-content: center; font-size: 9px; color: var(--d2);">
          Drop your species here
        </div>
      <% else %>
        <span style="font-size: 9px; color: var(--d2); font-style: italic; padding: 2px 8px;">waiting...</span>
      <% end %>
    </div>
  <% end %>
</div>
