<div class="pokedex-card bg-gray-700/40 border border-gray-600 rounded-lg px-3 py-2 cursor-grab active:cursor-grabbing hover:bg-gray-700/60 hover:border-gray-500 transition select-none flex items-center justify-between"
     data-species-name="<%= species_name %>">
  <span class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-200">
    <%= pokemon_sprite_tag(species_name, size: 24) %>
    <%= species_name %>
  </span>
  <svg class="w-4 h-4 text-gray-500 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
  </svg>
</div>
