<div class="pokedex-card gb-drag-item" style="display: flex; align-items: center; justify-content: space-between; padding: 6px 8px;"
     data-species-name="<%= species_name %>">
  <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 11px;">
    <%= pokemon_sprite_tag(species_name, size: 24) %>
    <%= species_name %>
    <%= pixeldex_type_badges(species_name) %>
  </span>
  <span style="font-size: 10px; color: var(--d2);">&#9776;</span>
</div>
