<div class="species-card bg-indigo-900/40 border border-indigo-700 rounded-lg px-3 py-2 cursor-grab active:cursor-grabbing hover:bg-indigo-900/60 hover:border-indigo-500 transition select-none flex items-center justify-between"
     data-pokemon-id="<%= pokemon.id %>">
  <span class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-200">
    <%= pokemon_sprite_tag(pokemon.species, size: 24) %>
    <%= pokemon.species %>
  </span>
  <svg class="w-4 h-4 text-indigo-500 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
  </svg>
</div>
