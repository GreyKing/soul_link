<div class="species-card gb-drag-item" style="display: flex; align-items: center; justify-content: space-between; background: var(--d2); color: var(--l2); padding: 6px 8px;"
     data-pokemon-id="<%= pokemon.id %>">
  <span style="display: inline-flex; align-items: center; gap: 4px; font-size: 11px;">
    <%= pokemon_sprite_tag(pokemon.species, size: 24) %>
    <%= pokemon.species %>
    <%= pixeldex_type_badges(pokemon.species) %>
  </span>
  <span style="font-size: 10px; color: var(--l1);">&#9776;</span>
</div>
