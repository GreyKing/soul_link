<div style="margin-bottom: 16px;">
  <div class="gb-page-title">SPECIES ASSIGNMENT</div>
  <div class="gb-page-subtitle">Drag your species from the pool onto the correct group.</div>
</div>

<div data-controller="species-assignment"
     data-species-assignment-assign-url-value="<%= assign_species_path %>"
     data-species-assignment-assign-from-pokedex-url-value="<%= assign_from_pokedex_species_path %>"
     data-species-assignment-unassign-url-value="<%= unassign_species_path %>"
     data-species-assignment-groups-url-value="<%= pokemon_groups_path %>"
     data-species-assignment-reorder-url-value="<%= reorder_pokemon_groups_path %>"
     data-species-assignment-csrf-value="<%= form_authenticity_token %>"
     data-species-assignment-user-id-value="<%= current_user_id %>"
     data-species-assignment-locations-value="<%= @locations.map { |k, v| { key: k, name: v['name'] } }.to_json %>"
     style="display: grid; grid-template-columns: 2fr 1fr; gap: 16px;">

  <%# ── ALL GROUPS (left area) ── %>
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
      <div style="font-size: 13px;">
        ALL GROUPS
        <span style="font-size: 10px; color: var(--d2);">(<%= @groups.size %> groups)</span>
      </div>
      <button type="button"
              data-action="click->species-assignment#openNewGroupModal"
              class="gb-btn-primary gb-btn-sm">
        + NEW GROUP
      </button>
    </div>

    <%# Quick-Nav %>
    <% if @groups.any? %>
      <div data-species-assignment-target="quickNavBar"
           style="display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px;">
        <% @groups.each do |group| %>
          <button type="button"
                  data-action="click->species-assignment#scrollToGroup"
                  data-scroll-to-group="<%= group.id %>"
                  class="gb-btn gb-btn-sm<%= ' gb-status-dead' if group.dead? %>"
                  style="padding: 2px 6px; font-size: 9px;">
            <%= group.nickname %>
          </button>
        <% end %>
      </div>
    <% end %>

    <div style="max-height: 75vh; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--d2) var(--l1);">
      <% @groups.each do |group| %>
        <%= render "group_card", group: group, current_user_id: current_user_id, players: @players %>
      <% end %>

      <% if @groups.empty? %>
        <div class="gb-card" style="font-size: 10px; color: var(--d2); text-align: center; padding: 20px;">
          No groups yet.
        </div>
      <% end %>
    </div>
  </div>

  <%# ── YOUR SPECIES PANEL (right column, tabbed) ── %>
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
      <div style="font-size: 13px;">
        YOUR SPECIES
        <span style="font-size: 10px; color: var(--d2);"
              data-species-assignment-target="poolCount">(<%= @pool.size %> remaining)</span>
      </div>
      <span data-species-assignment-target="saveStatus" style="font-size: 10px; color: var(--d2);"></span>
    </div>

    <%# Tab Buttons %>
    <div class="tab-bar" style="margin-bottom: 0;" role="tablist">
      <button type="button" role="tab" aria-selected="false"
              data-species-assignment-target="tabButton"
              data-action="click->species-assignment#switchTab"
              data-tab="pool"
              class="tab-item" style="font-size: 10px; padding: 6px;">
        YOUR POOL
      </button>
      <button type="button" role="tab" aria-selected="true"
              data-species-assignment-target="tabButton"
              data-action="click->species-assignment#switchTab"
              data-tab="pokedex"
              class="tab-item active" style="font-size: 10px; padding: 6px;">
        POKEDEX
      </button>
    </div>

    <%# Pool Tab %>
    <div data-species-assignment-target="tabPanel" data-tab="pool" class="hidden">
      <div data-species-assignment-target="poolList"
           class="gb-drag-zone" style="min-height: 200px; max-height: 75vh; overflow-y: auto; border-top: none;">
        <% @pool.each do |pokemon| %>
          <%= render "species_card", pokemon: pokemon %>
        <% end %>

        <div style="font-size: 10px; color: var(--d2); text-align: center; padding: 12px; <%= @pool.any? ? 'display: none;' : '' %>"
             data-species-assignment-target="poolEmpty">
          All species assigned!
        </div>
      </div>
    </div>

    <%# Pokedex Tab %>
    <div data-species-assignment-target="tabPanel" data-tab="pokedex">
      <div style="border: var(--border-thin); border-top: none; background: var(--l2);">
        <div style="padding: 8px; border-bottom: var(--border-thin);">
          <input type="text"
                 placeholder="Search species..."
                 data-species-assignment-target="pokedexSearch"
                 data-action="input->species-assignment#filterPokedex"
                 class="gb-input">
        </div>

        <div data-species-assignment-target="pokedexList"
             style="max-height: 65vh; overflow-y: auto; padding: 8px; scrollbar-width: thin; scrollbar-color: var(--d2) var(--l1);">
          <% @pokedex_species.each do |species_name| %>
            <%= render "pokedex_card", species_name: species_name %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── GROUP MODAL (create / edit) ── %>
  <div data-species-assignment-target="modal"
       class="hidden"
       style="position: fixed; inset: 0; z-index: 50;">
    <div data-action="click->species-assignment#closeModal"
         style="position: absolute; inset: 0; background: rgba(15, 56, 15, 0.75);"></div>

    <div style="position: relative; display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 16px;">
      <div class="gb-modal">
        <div class="gb-modal-title">
          <span data-species-assignment-target="modalTitle">NEW GROUP</span>
          <button data-action="click->species-assignment#closeModal"
                  class="gb-modal-close">&times;</button>
        </div>

        <form data-action="submit->species-assignment#submitGroup">
          <input type="hidden" data-species-assignment-target="groupIdInput">

          <div style="margin-bottom: 10px;">
            <label class="gb-label">NICKNAME</label>
            <input type="text" required autocomplete="off"
                   data-species-assignment-target="groupNicknameInput"
                   class="gb-input"
                   placeholder="e.g. Tommy, RACHEL...">
          </div>

          <div style="margin-bottom: 10px;">
            <label class="gb-label">LOCATION</label>
            <select data-species-assignment-target="groupLocationSelect"
                    required class="gb-select">
              <option value="">Select location...</option>
              <% @locations.each do |key, data| %>
                <option value="<%= key %>"><%= data['name'] %></option>
              <% end %>
            </select>
          </div>

          <div style="margin-bottom: 10px;">
            <label class="gb-label">STATUS</label>
            <select data-species-assignment-target="groupStatusSelect"
                    data-action="change->species-assignment#toggleEulogy"
                    class="gb-select">
              <option value="caught">Caught</option>
              <option value="dead">Dead</option>
            </select>
          </div>

          <div data-species-assignment-target="eulogyWrapper" class="hidden" style="margin-bottom: 10px;">
            <label class="gb-label">EULOGY</label>
            <input type="text" autocomplete="off"
                   data-species-assignment-target="groupEulogyInput"
                   class="gb-input"
                   placeholder="Rest in peace...">
          </div>

          <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 16px;">
            <span data-species-assignment-target="modalStatus" style="font-size: 10px; color: var(--d2);"></span>
            <div style="display: flex; gap: 8px;">
              <button type="button"
                      data-action="click->species-assignment#closeModal"
                      class="gb-btn gb-btn-sm">Cancel</button>
              <button type="submit" class="gb-btn-primary gb-btn-sm">SAVE</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
