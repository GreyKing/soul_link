<%# Each card is draggable. data-group-id is read by Sortable to persist order. %>
<div class="pokemon-card gb-drag-item"
     data-group-id="<%= group.id %>">
  <div style="display: flex; align-items: center; justify-content: space-between;">
    <div style="display: flex; align-items: center; gap: 6px;">
      <span class="position-badge hidden" style="font-size: 10px; color: var(--d2); width: 16px; text-align: center;"></span>
      <span style="font-size: 12px;"><%= group.nickname %></span>
      <span style="font-size: 9px; color: var(--d2);"><%= group.location %></span>
    </div>
    <span style="font-size: 10px; color: var(--d2);">&#9776;</span>
  </div>

  <div style="margin-top: 6px; display: flex; flex-wrap: wrap; gap: 4px;">
    <% group.soul_link_pokemon.each do |pokemon| %>
      <% is_mine = pokemon.discord_user_id == current_user_id %>
      <span style="display: inline-flex; align-items: center; gap: 3px; font-size: 10px; padding: 2px 6px;
                   border: var(--border-thin); <%= is_mine ? 'background: var(--d2); color: var(--l2);' : 'background: var(--l2); color: var(--d2);' %>">
        <%= pokemon_sprite_tag(pokemon.species, size: 20) %>
        <span style="<%= is_mine ? 'color: var(--l2);' : 'color: var(--d2);' %>"><%= SoulLink::GameState.player_name(pokemon.discord_user_id) %></span>
        <span style="<%= is_mine ? 'color: var(--l1);' : 'color: var(--d2);' %>"><%= pokemon.species %></span>
        <%= pixeldex_type_badges(pokemon.species) %>
        <button data-action="click->quick-calc#open"
                data-species="<%= pokemon.species %>"
                data-level="<%= pokemon.level || 50 %>"
                data-nature="<%= pokemon.nature %>"
                title="Calculate damage"
                style="background: none; border: var(--border-thin); cursor: pointer; font-size: 10px; padding: 1px 4px; color: inherit; line-height: 1;">&#9876;</button>
      </span>
    <% end %>
  </div>
</div>
