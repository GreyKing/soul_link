<div class="mb-6">
  <h1 class="text-2xl font-bold text-white">All Teams</h1>
  <p class="text-gray-400 text-sm mt-1">Everyone's team at a glance.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
  <% @players.each do |player| %>
    <% team = @teams.find { |t| t.discord_user_id == player['discord_user_id'] } %>
    <div class="bg-gray-800 rounded-xl border border-gray-700 p-4">
      <h2 class="text-lg font-semibold text-white mb-3">
        <%= player['display_name'] %>
        <% if team %>
          <span class="text-xs text-gray-500 font-normal">(<%= team.soul_link_team_slots.size %>/<%= SoulLinkTeam::MAX_SLOTS %>)</span>
        <% end %>
      </h2>

      <% if team && team.soul_link_team_slots.any? %>
        <div class="space-y-2">
          <% team.soul_link_team_slots.each do |slot| %>
            <% group = slot.soul_link_pokemon_group %>
            <div class="bg-gray-900/50 rounded-lg border border-gray-700/50 p-2">
              <div class="flex items-center justify-between">
                <span class="font-medium text-white text-sm"><%= group.nickname %></span>
                <span class="text-xs text-gray-500">#<%= slot.position %></span>
              </div>
              <div class="mt-1 flex flex-wrap gap-1">
                <% group.soul_link_pokemon.each do |pokemon| %>
                  <% is_this_player = pokemon.discord_user_id == player['discord_user_id'] %>
                  <span class="text-xs <%= is_this_player ? 'text-indigo-300 font-medium' : 'text-gray-500' %>">
                    <%= pokemon.species %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm text-center py-6">No team built yet</p>
      <% end %>
    </div>
  <% end %>
</div>

<% if @players.empty? %>
  <p class="text-gray-500 text-center py-12">No players configured in settings.yml yet.</p>
<% end %>
