<div style="margin-bottom: 16px;">
  <div class="gb-page-title">ALL TEAMS</div>
  <div class="gb-page-subtitle">Everyone's team at a glance.</div>
</div>

<div class="gb-grid-4">
  <% @players.each do |player| %>
    <% team = @teams.find { |t| t.discord_user_id == player['discord_user_id'] } %>
    <div class="gb-card" style="padding: 12px;">
      <div style="font-size: 13px; margin-bottom: 8px;">
        <%= player['display_name'].upcase %>
        <% if team %>
          <span style="font-size: 9px; color: var(--d2);">(<%= team.soul_link_team_slots.size %>/<%= SoulLinkTeam::MAX_SLOTS %>)</span>
        <% end %>
      </div>

      <% if team && team.soul_link_team_slots.any? %>
        <% team.soul_link_team_slots.each do |slot| %>
          <% group = slot.soul_link_pokemon_group %>
          <div class="gb-card-dark" style="padding: 6px 8px; margin-bottom: 4px;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
              <span style="font-size: 11px; color: var(--l2);"><%= group.nickname %></span>
              <span style="font-size: 9px; color: var(--l1);">#<%= slot.position %></span>
            </div>
            <% my_pokemon = group.soul_link_pokemon.find { |p| p.discord_user_id == player['discord_user_id'] } %>
            <% if my_pokemon %>
              <div style="margin-top: 4px; display: flex; align-items: center; gap: 4px;">
                <%= pokemon_sprite_tag(my_pokemon.species, size: 32) %>
                <span style="font-size: 10px; color: var(--l1);"><%= my_pokemon.species %></span>
                <%= pixeldex_type_badges(my_pokemon.species) %>
              </div>
            <% else %>
              <div style="margin-top: 4px; font-size: 9px; color: var(--l1); font-style: italic;">No species assigned</div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div style="font-size: 10px; color: var(--d2); text-align: center; padding: 16px;">No team built yet</div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @players.empty? %>
  <div class="gb-card" style="font-size: 10px; color: var(--d2); text-align: center; padding: 24px;">
    No players configured in settings.yml yet.
  </div>
<% end %>
