<div class="mb-6">
  <h1 class="text-2xl font-bold text-white"><%= @player_name %>'s Team</h1>
  <p class="text-gray-400 text-sm mt-1">Drag Pokemon between your team and the pool. Max 6 per team.</p>
</div>

<div data-controller="team-builder"
     data-team-builder-update-url-value="<%= update_slots_team_path %>"
     data-team-builder-csrf-value="<%= form_authenticity_token %>"
     data-team-builder-user-id-value="<%= current_user_id %>"
     class="grid grid-cols-1 lg:grid-cols-2 gap-8">

  <%# ── YOUR TEAM (left column) ── %>
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-white">
        Your Team
        <span class="text-sm font-normal text-gray-400"
              data-team-builder-target="teamCount">(<%= @team_groups.size %>/<%= SoulLinkTeam::MAX_SLOTS %>)</span>
      </h2>
      <span data-team-builder-target="saveStatus" class="text-xs text-gray-500"></span>
    </div>

    <div data-team-builder-target="teamList"
         class="space-y-3 min-h-[200px] p-4 bg-gray-800/50 rounded-xl border-2 border-dashed border-gray-700">
      <% if @team_groups.empty? %>
        <p class="text-gray-500 text-sm text-center py-8" data-team-builder-target="teamEmpty">
          Drag Pokemon here to build your team
        </p>
      <% end %>
      <% @team_groups.each do |group| %>
        <%= render "pokemon_card", group: group, current_user_id: current_user_id %>
      <% end %>
    </div>
  </div>

  <%# ── AVAILABLE POOL (right column) ── %>
  <div>
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-lg font-semibold text-white">
        Available Pool
        <span class="text-sm font-normal text-gray-400">(<%= @pool_groups.size %> caught)</span>
      </h2>
    </div>

    <div class="relative mb-3">
      <input type="text"
             data-team-builder-target="poolSearch"
             data-action="input->team-builder#filterPool"
             placeholder="Search by name, species, or location..."
             class="w-full bg-gray-900 border border-gray-600 rounded-lg pl-8 pr-3 py-2 text-white text-sm
                    focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 focus:outline-none placeholder-gray-500">
      <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>

    <div data-team-builder-target="poolList"
         class="space-y-3 min-h-[200px] max-h-[60vh] overflow-y-auto p-4 bg-gray-800/50 rounded-xl border-2 border-dashed border-gray-600">
      <% if @pool_groups.empty? %>
        <p class="text-gray-500 text-sm text-center py-8" data-team-builder-target="poolEmpty">
          All caught Pokemon are on your team!
        </p>
      <% end %>
      <% @pool_groups.each do |group| %>
        <%= render "pokemon_card", group: group, current_user_id: current_user_id %>
      <% end %>
    </div>
  </div>
</div>
