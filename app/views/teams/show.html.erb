<div data-controller="quick-calc"
     data-quick-calc-csrf-value="<%= form_authenticity_token %>"
     data-quick-calc-pokemon-url-value="/api/pokemon/"
     data-quick-calc-calc-url-value="/api/calculator">

<div style="margin-bottom: 16px;">
  <div class="gb-page-title"><%= @player_name&.upcase || "TRAINER" %>'S TEAM</div>
  <div class="gb-page-subtitle">Drag Pokemon between your team and the pool. Max 6 per team.</div>
</div>

<div data-controller="team-builder"
     data-team-builder-update-url-value="<%= update_slots_team_path %>"
     data-team-builder-csrf-value="<%= form_authenticity_token %>"
     data-team-builder-user-id-value="<%= current_user_id %>"
     class="gb-grid-2">

  <%# ── YOUR TEAM (left column) ── %>
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
      <div style="font-size: 13px;">
        YOUR TEAM
        <span style="font-size: 10px; color: var(--d2);"
              data-team-builder-target="teamCount">(<%= @team_groups.size %>/<%= SoulLinkTeam::MAX_SLOTS %>)</span>
      </div>
      <span data-team-builder-target="saveStatus" style="font-size: 10px; color: var(--d2);"></span>
    </div>

    <div data-team-builder-target="teamList"
         class="gb-drag-zone" style="min-height: 200px;">
      <% if @team_groups.empty? %>
        <div style="font-size: 10px; color: var(--d2); text-align: center; padding: 24px;" data-team-builder-target="teamEmpty">
          Drag Pokemon here to build your team
        </div>
      <% end %>
      <% @team_groups.each do |group| %>
        <%= render "pokemon_card", group: group, current_user_id: current_user_id %>
      <% end %>
    </div>
  </div>

  <%# ── AVAILABLE POOL (right column) ── %>
  <div>
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
      <div style="font-size: 13px;">
        AVAILABLE POOL
        <span style="font-size: 10px; color: var(--d2);">(<%= @pool_groups.size %> caught)</span>
      </div>
    </div>

    <div style="margin-bottom: 8px;">
      <input type="text"
             data-team-builder-target="poolSearch"
             data-action="input->team-builder#filterPool"
             placeholder="Search..."
             class="gb-input">
    </div>

    <div data-team-builder-target="poolList"
         class="gb-drag-zone" style="min-height: 200px; max-height: 60vh; overflow-y: auto;">
      <% if @pool_groups.empty? %>
        <div style="font-size: 10px; color: var(--d2); text-align: center; padding: 24px;" data-team-builder-target="poolEmpty">
          All caught Pokemon are on your team!
        </div>
      <% end %>
      <% @pool_groups.each do |group| %>
        <%= render "pokemon_card", group: group, current_user_id: current_user_id %>
      <% end %>
    </div>
  </div>
</div>

<%= render "quick_calc_modal" %>
</div>
